+++ b/.github/workflows/scripts/notify-review-failure.sh
@@ -0,0 +1,70 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+# Emit a durable failure signal when the scheduled codebase-review workflow
+# fails. A workflow annotation alone is not a notification for a job that runs
+# unattended every week, so this opens (or updates) a tracking issue that
+# persists until a human closes it.
+#
+# Required env vars:
+#   GH_TOKEN
+#   REPO    - GitHub repository (owner/repo)
+#   RUN_URL - URL of the failed workflow run
+#
+# Optional env vars (per-job results, for context in the alert):
+#   DETERMINE_RESULT
+#   REVIEW_RESULT
+#   FIX_RESULT
+
+: "${GH_TOKEN:?}" "${REPO:?}" "${RUN_URL:?}"
+
+DETERMINE_RESULT="${DETERMINE_RESULT:-unknown}"
+REVIEW_RESULT="${REVIEW_RESULT:-unknown}"
+FIX_RESULT="${FIX_RESULT:-unknown}"
+
+echo "::warning::Codebase review workflow failed (determine-area=${DETERMINE_RESULT}, review=${REVIEW_RESULT}, fix=${FIX_RESULT}). See ${RUN_URL}"
+
+FAIL_LABEL="auto-review-failure"
+TITLE="Automated codebase review workflow failed"
+SUMMARY="determine-area=${DETERMINE_RESULT}, review=${REVIEW_RESULT}, fix=${FIX_RESULT}"
+
+read -r -d '' BODY <<EOF || true
+The scheduled **Automated Codebase Review** workflow failed.
+
+| Job | Result |
+| --- | --- |
+| determine-area | ${DETERMINE_RESULT} |
+| review | ${REVIEW_RESULT} |
+| fix | ${FIX_RESULT} |
+
+Failed run: ${RUN_URL}
+
+This issue was opened automatically because the weekly review runs unattended
+and its failures would otherwise be invisible in the run logs. Investigate the
+run above, then close this issue once resolved.
+
+To route these alerts to Slack/email instead, replace the notify step's script
+with your alerting action (e.g. slackapi/slack-github-action).
+EOF
+
+# Ensure the tracking label exists (idempotent).
+gh label create "${FAIL_LABEL}" --repo "${REPO}" \
+  --color B60205 --description "Automated review workflow failures" 2>/dev/null || true
+
+# De-duplicate: if an open failure issue already exists, comment on it instead
+# of opening a new one so repeated failures do not spam the tracker.
+EXISTING=$(gh issue list --repo "${REPO}" --state open \
+  --label "${FAIL_LABEL}" --search "${TITLE} in:title" \
+  --json number --jq '.[0].number' 2>/dev/null || true)
+
+if [[ -n "${EXISTING}" ]]; then
+  echo "Existing failure issue ${EXISTING} found; adding a comment."
+  gh issue comment "${EXISTING}" --repo "${REPO}" \
+    --body "Workflow failed again (${SUMMARY}). Failed run: ${RUN_URL}"
+else
+  echo "Opening a new failure tracking issue."
+  gh issue create --repo "${REPO}" \
+    --title "${TITLE}" \
+    --label "${FAIL_LABEL}" \
+    --body "${BODY}"
+fi
