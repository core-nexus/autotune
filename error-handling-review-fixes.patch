@@ -0,0 +1,88 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+# Self-contained tests for the priority-extraction scripts.
+#
+# These verify the core error-handling guarantee: a genuine `gh` failure must
+# resolve to UNKNOWN, never to NONE (which would silently skip the fix stage),
+# while a successful call with no marker still resolves to NONE.
+#
+# `gh` is stubbed via a temporary PATH entry whose behaviour is controlled by
+# the GH_STUB_MODE env var, so no network or auth is required.
+#
+# Usage: .github/workflows/scripts/tests/test-extract-priority.sh
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+PR_SCRIPT="${SCRIPT_DIR}/extract-pr-review-priority.sh"
+AREA_SCRIPT="${SCRIPT_DIR}/extract-review-priority.sh"
+
+WORKDIR="$(mktemp -d)"
+trap 'rm -rf "${WORKDIR}"' EXIT
+
+# ── Build a stub `gh` on PATH ───────────────────────────────────────────────
+STUB_BIN="${WORKDIR}/bin"
+mkdir -p "${STUB_BIN}"
+cat > "${STUB_BIN}/gh" <<'STUB'
+#!/usr/bin/env bash
+# Stub gh. GH_STUB_MODE selects behaviour:
+#   marker-high : succeed, output a body containing MAXIMUM_FIX_PRIORITY:HIGH
+#   no-marker   : succeed, output a body with no marker
+#   fail        : print an error to stderr and exit non-zero (API failure)
+case "${GH_STUB_MODE:-}" in
+  marker-high) echo "some text MAXIMUM_FIX_PRIORITY:HIGH more text"; exit 0 ;;
+  no-marker)   echo "a normal review with no marker"; exit 0 ;;
+  fail)        echo "gh: HTTP 401: Bad credentials" >&2; exit 1 ;;
+  *)           echo "gh stub: unset GH_STUB_MODE" >&2; exit 99 ;;
+esac
+STUB
+chmod +x "${STUB_BIN}/gh"
+export PATH="${STUB_BIN}:${PATH}"
+
+PASS=0
+FAIL=0
+
+# run_case <label> <script> <expected-priority>
+# Remaining env (GH_STUB_MODE, EXECUTION_FILE, ...) is inherited from the caller.
+run_case() {
+  local label="$1" script="$2" expected="$3"
+  local out_file="${WORKDIR}/out.$$"
+  : > "${out_file}"
+  GITHUB_OUTPUT="${out_file}" bash "${script}" >/dev/null 2>&1 || true
+  local actual
+  actual="$(grep -oP '(?<=^priority=).*' "${out_file}" | tail -1 || true)"
+  if [[ "${actual}" == "${expected}" ]]; then
+    echo "PASS: ${label} (priority=${actual})"
+    PASS=$((PASS + 1))
+  else
+    echo "FAIL: ${label} — expected '${expected}', got '${actual}'"
+    FAIL=$((FAIL + 1))
+  fi
+}
+
+echo "== extract-pr-review-priority.sh =="
+REPO="o/r" PR_NUMBER="1" GH_STUB_MODE="marker-high" \
+  run_case "PR: marker present -> HIGH" "${PR_SCRIPT}" "HIGH"
+REPO="o/r" PR_NUMBER="1" GH_STUB_MODE="no-marker" \
+  run_case "PR: success, no marker -> NONE" "${PR_SCRIPT}" "NONE"
+REPO="o/r" PR_NUMBER="1" GH_STUB_MODE="fail" \
+  run_case "PR: api failure -> UNKNOWN (not NONE)" "${PR_SCRIPT}" "UNKNOWN"
+
+echo "== extract-review-priority.sh =="
+# Execution-file path wins and never calls gh.
+EXEC_HIGH="${WORKDIR}/exec-high.txt"
+printf 'blah\nMAXIMUM_FIX_PRIORITY:MEDIUM\n' > "${EXEC_HIGH}"
+REPO="o/r" REVIEW_AREA="error-handling" EXECUTION_FILE="${EXEC_HIGH}" GH_STUB_MODE="fail" \
+  run_case "area: execution file -> MEDIUM (gh not consulted)" "${AREA_SCRIPT}" "MEDIUM"
+# Fallback to gh, marker present.
+REPO="o/r" REVIEW_AREA="error-handling" GH_STUB_MODE="marker-high" \
+  run_case "area: gh fallback marker -> HIGH" "${AREA_SCRIPT}" "HIGH"
+# Fallback to gh, success but no matching issue/body.
+REPO="o/r" REVIEW_AREA="error-handling" GH_STUB_MODE="no-marker" \
+  run_case "area: gh fallback no marker -> NONE" "${AREA_SCRIPT}" "NONE"
+# Fallback to gh, API failure -> UNKNOWN, not NONE.
+REPO="o/r" REVIEW_AREA="error-handling" GH_STUB_MODE="fail" \
+  run_case "area: gh fallback failure -> UNKNOWN (not NONE)" "${AREA_SCRIPT}" "UNKNOWN"
+
+echo ""
+echo "Results: ${PASS} passed, ${FAIL} failed"
+[[ "${FAIL}" -eq 0 ]]
