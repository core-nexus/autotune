@@ -0,0 +1,60 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+# Tests for trigger-ci-workflows.sh error classification.
+#
+# Verifies that a genuine dispatch failure (bad token, permissions, network) is
+# reported as a real error and fails the step, while a "not found" workflow is
+# treated as a benign skip — the mislabeling this fixes.
+#
+# `gh` is stubbed via PATH; GH_STUB_MODE controls its behaviour.
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+TRIGGER_SCRIPT="${SCRIPT_DIR}/trigger-ci-workflows.sh"
+
+WORKDIR="$(mktemp -d)"
+trap 'rm -rf "${WORKDIR}"' EXIT
+
+STUB_BIN="${WORKDIR}/bin"
+mkdir -p "${STUB_BIN}"
+cat > "${STUB_BIN}/gh" <<'STUB'
+#!/usr/bin/env bash
+# Stub `gh workflow run ...`. GH_STUB_MODE selects behaviour:
+#   ok        : succeed
+#   not-found : fail with a "could not find" message (benign skip)
+#   forbidden : fail with a permissions error (real error)
+case "${GH_STUB_MODE:-}" in
+  ok)        exit 0 ;;
+  not-found) echo "could not find any workflows named ci.yml" >&2; exit 1 ;;
+  forbidden) echo "HTTP 403: Resource not accessible by integration" >&2; exit 1 ;;
+  *)         echo "gh stub: unset GH_STUB_MODE" >&2; exit 99 ;;
+esac
+STUB
+chmod +x "${STUB_BIN}/gh"
+export PATH="${STUB_BIN}:${PATH}"
+
+PASS=0
+FAIL=0
+
+# run_case <label> <expected-exit>
+run_case() {
+  local label="$1" expected_exit="$2"
+  local rc=0
+  REPO="o/r" BRANCH="review/x" WORKFLOWS="ci.yml" \
+    bash "${TRIGGER_SCRIPT}" >/dev/null 2>&1 || rc=$?
+  if [[ "${rc}" -eq "${expected_exit}" ]]; then
+    echo "PASS: ${label} (exit=${rc})"
+    PASS=$((PASS + 1))
+  else
+    echo "FAIL: ${label} — expected exit ${expected_exit}, got ${rc}"
+    FAIL=$((FAIL + 1))
+  fi
+}
+
+GH_STUB_MODE="ok"        run_case "successful dispatch -> exit 0" 0
+GH_STUB_MODE="not-found" run_case "not-found -> benign skip, exit 0" 0
+GH_STUB_MODE="forbidden" run_case "permissions error -> real error, exit 1" 1
+
+echo ""
+echo "Results: ${PASS} passed, ${FAIL} failed"
+[[ "${FAIL}" -eq 0 ]]
