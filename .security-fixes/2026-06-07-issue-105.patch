-ALL_AREAS='["security","privacy","compliance","ai-compliance","error-handling","code-quality","performance","testing","documentation","dependency-health","correctness","e-commerce"]'
+# Ordered list of valid areas. Kept in sync with the workflow_dispatch choices.
+AREAS=(security privacy compliance ai-compliance error-handling code-quality \
+  performance testing documentation dependency-health correctness e-commerce)
+
+# Build the JSON array form once from the canonical list above.
+ALL_AREAS=$(printf '%s\n' "${AREAS[@]}" | jq -R . | jq -cs .)
 
 if [[ "${EVENT_NAME}" = "workflow_dispatch" ]]; then
   AREA="${INPUT_REVIEW_AREA:-security}"
+
   if [[ "${AREA}" = "all" ]]; then
     echo "areas_json=${ALL_AREAS}" >> "${GITHUB_OUTPUT}"
   else
+    # Validate AREA against the allowlist before writing it to GITHUB_OUTPUT.
+    # The workflow_dispatch input is `type: choice` (server-constrained today),
+    # but validating here is defense-in-depth against GITHUB_OUTPUT injection if
+    # the input source ever changes — a newline-bearing or unknown value is
+    # rejected outright rather than echoed into a step output (see item 5).
+    valid=false
+    for known in "${AREAS[@]}"; do
+      if [[ "${AREA}" = "${known}" ]]; then
+        valid=true
+        break
+      fi
+    done
+
+    if [[ "${valid}" != "true" ]]; then
+      echo "::error::Invalid review area: '${AREA}'. Expected one of: ${AREAS[*]} or 'all'." >&2
+      exit 1
+    fi
+
+    # AREA is now known to be one of the literal allowlist entries (no newlines,
+    # no metacharacters), so embedding it in the JSON array is safe.
     echo "areas_json=[\"${AREA}\"]" >> "${GITHUB_OUTPUT}"
   fi
 else
