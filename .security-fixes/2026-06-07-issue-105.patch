+name: Scripts CI
+
+# Lints and tests the review helper scripts. Runs on any change to the scripts,
+# the workflows that call them, or the tests themselves.
+
+on:
+  push:
+    paths:
+      - '.github/workflows/scripts/**'
+      - '.github/workflows/*.yml'
+      - 'tests/**'
+  pull_request:
+    paths:
+      - '.github/workflows/scripts/**'
+      - '.github/workflows/*.yml'
+      - 'tests/**'
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+jobs:
+  test:
+    runs-on: ubuntu-latest
+    timeout-minutes: 10
+    steps:
+      - name: Checkout repository
+        uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4
+
+      - name: ShellCheck helper scripts and tests
+        run: shellcheck .github/workflows/scripts/*.sh tests/*.sh
+
+      - name: Run script unit tests
+        run: bash tests/test-review-scripts.sh
diff --git a/.github/workflows/scripts/extract-pr-review-priority.sh b/.github/workflows/scripts/extract-pr-review-priority.sh
index c28572e..c2d5c8b 100755
--- a/.github/workflows/scripts/extract-pr-review-priority.sh
+++ b/.github/workflows/scripts/extract-pr-review-priority.sh
@@ -3,6 +3,12 @@ set -euo pipefail
 
 # Extract MAXIMUM_FIX_PRIORITY from the latest PR review comment.
 #
+# Only comments authored by a bot account (the review bot) are trusted. A human
+# commenter must NOT be able to spoof the priority gate by posting their own
+# "MAXIMUM_FIX_PRIORITY:HIGH" / ":NONE" line — that would let an untrusted actor
+# force or suppress the write-scoped fix job (see item 2). We therefore filter
+# the comment list to author type "Bot" before reading the priority.
+#
 # Required env vars:
 #   GITHUB_OUTPUT
 #   GH_TOKEN
@@ -11,9 +17,21 @@ set -euo pipefail
 
 : "${GITHUB_OUTPUT:?}" "${REPO:?}" "${PR_NUMBER:?}"
 
-PRIORITY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
-  --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' 2>/dev/null \
-  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || echo "NONE")
+# Fetch comments once. On failure, log the reason (item 7) and fail closed to NONE
+# so a transient API error never spuriously triggers the write-scoped fix job.
+if ! COMMENTS=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" --paginate 2>&1); then
+  echo "::warning::Failed to fetch PR comments for ${REPO} item ${PR_NUMBER}; defaulting priority to NONE. Details: ${COMMENTS}" >&2
+  COMMENTS="[]"
+fi
+
+# Select the last bot-authored comment carrying a priority marker, then read the
+# value. Restricting to `.user.type == "Bot"` is the trust boundary for the gate.
+PRIORITY=$(printf '%s' "${COMMENTS}" \
+  | jq -r '[.[] | select(.user.type == "Bot") | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body // ""' \
+  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' \
+  || true)
+
+PRIORITY="${PRIORITY:-NONE}"
 
 echo "MAXIMUM_FIX_PRIORITY: ${PRIORITY}"
 echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
