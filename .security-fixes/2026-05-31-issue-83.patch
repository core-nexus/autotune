+ALLOWED_AREAS=(
+  security privacy compliance ai-compliance error-handling
+  code-quality performance testing documentation
+  dependency-health correctness e-commerce
+)
+ALL_AREAS_JSON='["security","privacy","compliance","ai-compliance","error-handling","code-quality","performance","testing","documentation","dependency-health","correctness","e-commerce"]'
+
+# Use heredoc form to write GITHUB_OUTPUT so embedded newlines can't inject
+# additional outputs. Pick a delimiter unlikely to appear in any value.
+write_output() {
+  local key="$1"
+  local value="$2"
+  local delim
+  delim="EOF_$(date +%s)_$$_$RANDOM"
+  {
+    printf '%s<<%s\n' "${key}" "${delim}"
+    printf '%s\n' "${value}"
+    printf '%s\n' "${delim}"
+  } >> "${GITHUB_OUTPUT}"
