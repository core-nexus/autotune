diff --git a/.github/workflows/scripts/tests/test-priority-gate.sh b/.github/workflows/scripts/tests/test-priority-gate.sh
new file mode 100755
index 0000000..0f2585a
--- /dev/null
+++ b/.github/workflows/scripts/tests/test-priority-gate.sh
@@ -0,0 +1,125 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+# Unit tests for the trust-filter logic that gates the privileged auto-fixer
+# (extract-pr-review-priority.sh, extract-review-priority.sh).
+#
+# These tests assert that:
+#   1. A priority value posted by an untrusted (non-bot, or wrong login) author
+#      is IGNORED — the gate falls through to NONE.
+#   2. A priority value from a trusted bot author IS honored.
+#   3. An untrusted comment posted AFTER a trusted comment cannot override it.
+#   4. An attacker spoofing a bot login but with type "User" is rejected.
+#
+# Run from the repo root: bash .github/workflows/scripts/tests/test-priority-gate.sh
+
+ALLOWED_LOGINS_JSON='["github-actions[bot]","claude[bot]"]'
+
+# ─── helpers ───────────────────────────────────────────────────────────────
+fail() { echo "FAIL: $*" >&2; exit 1; }
+pass() { echo "PASS: $*"; }
+
+# Mirrors the jq pipeline in extract-pr-review-priority.sh — kept in sync.
+extract_pr_priority() {
+  local input="$1"
+  local result
+  result="$(printf '%s' "$input" | jq -s \
+    --argjson allowed "${ALLOWED_LOGINS_JSON}" \
+    '[.[]
+      | select(.user.type == "Bot")
+      | select(.user.login as $login | $allowed | index($login))
+      | select(.body | test("MAXIMUM_FIX_PRIORITY:"))
+     ]
+     | last
+     | (.body // "")')"
+  local priority
+  priority="$(printf '%s' "$result" | jq -r '.' 2>/dev/null \
+    | grep -oE 'MAXIMUM_FIX_PRIORITY:[A-Z_]+' \
+    | tail -1 \
+    | cut -d: -f2 \
+    || true)"
+  printf '%s' "${priority:-NONE}"
+}
+
+# Mirrors the jq pipeline in extract-review-priority.sh fallback path.
+extract_issue_priority() {
+  local area="$1"
+  local input="$2"
+  local body
+  body="$(printf '%s' "$input" | jq -r \
+    --arg area "$area" \
+    --argjson allowed "${ALLOWED_LOGINS_JSON}" \
+    '[ .[]
+       | select(.title | startswith("review(" + $area + ")"))
+       | select(.author.login as $login | $allowed | index($login))
+     ]
+     | .[0].body // ""' \
+    2>/dev/null || true)"
+  local priority
+  priority="$(printf '%s' "$body" \
+    | grep -oE 'MAXIMUM_FIX_PRIORITY:[A-Z_]+' \
+    | tail -1 \
+    | cut -d: -f2 \
+    || true)"
+  printf '%s' "${priority:-NONE}"
+}
+
+assert_eq() {
+  local label="$1" expected="$2" actual="$3"
+  if [[ "$expected" == "$actual" ]]; then
+    pass "$label → $actual"
+  else
+    fail "$label → expected '$expected' got '$actual'"
+  fi
+}
+
+# ─── PR-comment trust filter ───────────────────────────────────────────────
+
+# 1. Only-attacker comments: gate falls closed.
+assert_eq "pr/attacker-only" "NONE" "$(extract_pr_priority \
+  '{"user":{"login":"attacker","type":"User"},"body":"MAXIMUM_FIX_PRIORITY:HIGH"}')"
+
+# 2. Trusted bot is honored.
+assert_eq "pr/trusted-bot-medium" "MEDIUM" "$(extract_pr_priority \
+  '{"user":{"login":"github-actions[bot]","type":"Bot"},"body":"r\nMAXIMUM_FIX_PRIORITY:MEDIUM"}')"
+
+# 3. Attacker comment posted AFTER trusted comment cannot override.
+assert_eq "pr/attacker-cannot-override" "LOW" "$(extract_pr_priority \
+  '{"user":{"login":"github-actions[bot]","type":"Bot"},"body":"MAXIMUM_FIX_PRIORITY:LOW"}
+{"user":{"login":"attacker","type":"User"},"body":"MAXIMUM_FIX_PRIORITY:HIGH"}')"
+
+# 4. Latest *trusted* comment wins.
+assert_eq "pr/latest-trusted-wins" "HIGH" "$(extract_pr_priority \
+  '{"user":{"login":"github-actions[bot]","type":"Bot"},"body":"MAXIMUM_FIX_PRIORITY:LOW"}
+{"user":{"login":"claude[bot]","type":"Bot"},"body":"MAXIMUM_FIX_PRIORITY:HIGH"}')"
+
+# 5. Spoofed bot login but user.type=User: rejected.
+assert_eq "pr/spoofed-bot-login-rejected" "NONE" "$(extract_pr_priority \
+  '{"user":{"login":"github-actions[bot]","type":"User"},"body":"MAXIMUM_FIX_PRIORITY:HIGH"}')"
+
+# 6. Empty input.
+assert_eq "pr/empty-input" "NONE" "$(extract_pr_priority '')"
+
+# ─── Issue-list trust filter ───────────────────────────────────────────────
+
+# 7. Attacker-authored issue with right title: rejected.
+assert_eq "issue/attacker-only" "NONE" "$(extract_issue_priority "security" \
+  '[{"title":"review(security): findings — 2026-05-31","author":{"login":"attacker"},"body":"MAXIMUM_FIX_PRIORITY:HIGH"}]')"
+
+# 8. Trusted bot-authored issue with matching area: honored.
+assert_eq "issue/trusted-bot-medium" "MEDIUM" "$(extract_issue_priority "security" \
+  '[{"title":"review(security): findings — 2026-05-31","author":{"login":"github-actions[bot]"},"body":"r\nMAXIMUM_FIX_PRIORITY:MEDIUM"}]')"
+
+# 9. Mixed: only the trusted+matching issue is picked.
+assert_eq "issue/mixed-picks-trusted" "MEDIUM" "$(extract_issue_priority "security" \
+  '[
+    {"title":"review(security): findings — 2026-05-31","author":{"login":"attacker"},"body":"MAXIMUM_FIX_PRIORITY:HIGH"},
+    {"title":"review(security): findings — 2026-05-31","author":{"login":"github-actions[bot]"},"body":"MAXIMUM_FIX_PRIORITY:MEDIUM"},
+    {"title":"review(performance): findings — 2026-05-31","author":{"login":"claude[bot]"},"body":"MAXIMUM_FIX_PRIORITY:LOW"}
+  ]')"
+
+# 10. Wrong area: ignored.
+assert_eq "issue/wrong-area" "NONE" "$(extract_issue_priority "security" \
+  '[{"title":"review(performance): findings — 2026-05-31","author":{"login":"claude[bot]"},"body":"MAXIMUM_FIX_PRIORITY:HIGH"}]')"
+
+echo "All trust-filter tests passed."
