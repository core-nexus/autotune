+++ b/.github/workflows/scripts/tests/test-resolve-review-area.sh
@@ -0,0 +1,100 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+# Unit tests for resolve-review-area.sh.
+#
+# Asserts that:
+#   1. A valid single area produces a single-element JSON array.
+#   2. "all" expands to the full area list.
+#   3. The schedule trigger expands to the full area list.
+#   4. An area NOT in the allowlist is rejected (script exits non-zero,
+#      writes nothing to GITHUB_OUTPUT). This is the key security boundary.
+#   5. An area with newline/injection characters is rejected.
+#
+# Run from the repo root:
+#   bash .github/workflows/scripts/tests/test-resolve-review-area.sh
+
+SCRIPT="$(cd "$(dirname "$0")/.." && pwd)/resolve-review-area.sh"
+if [[ ! -x "$SCRIPT" ]]; then
+  echo "Cannot find executable script at $SCRIPT" >&2
+  exit 1
+fi
+
+run_script() {
+  # Usage: run_script <event_name> <input_area_or_empty> <out_var_for_output_file> <out_var_for_exit_code>
+  local event="$1" input="$2"
+  local outfile; outfile="$(mktemp)"
+  local rc=0
+  GITHUB_OUTPUT="$outfile" EVENT_NAME="$event" INPUT_REVIEW_AREA="$input" \
+    "$SCRIPT" >/dev/null 2>&1 || rc=$?
+  printf '%s\n%s\n' "$rc" "$outfile"
+}
+
+assert_contains() {
+  local label="$1" needle="$2" file="$3"
+  if grep -qF "$needle" "$file"; then
+    echo "PASS: $label"
+  else
+    echo "FAIL: $label — expected to find '$needle' in:"
+    cat "$file"
+    exit 1
+  fi
+}
+
+assert_exit() {
+  local label="$1" expected="$2" actual="$3"
+  if [[ "$expected" == "$actual" ]]; then
+    echo "PASS: $label (exit=$actual)"
+  else
+    echo "FAIL: $label — expected exit $expected, got $actual"
+    exit 1
+  fi
+}
+
+assert_file_empty() {
+  local label="$1" file="$2"
+  if [[ ! -s "$file" ]]; then
+    echo "PASS: $label (GITHUB_OUTPUT empty)"
+  else
+    echo "FAIL: $label — expected GITHUB_OUTPUT empty, got:"
+    cat "$file"
+    exit 1
+  fi
+}
+
+# 1. Valid single area
+out=$(run_script "workflow_dispatch" "security")
+rc=$(echo "$out" | sed -n '1p'); f=$(echo "$out" | sed -n '2p')
+assert_exit "valid-single-area exit" "0" "$rc"
+assert_contains "valid-single-area output" '["security"]' "$f"
+rm -f "$f"
+
+# 2. "all" -> full list
+out=$(run_script "workflow_dispatch" "all")
+rc=$(echo "$out" | sed -n '1p'); f=$(echo "$out" | sed -n '2p')
+assert_exit "all-areas exit" "0" "$rc"
+assert_contains "all-areas output" '"security","privacy"' "$f"
+rm -f "$f"
+
+# 3. Schedule trigger -> full list
+out=$(run_script "schedule" "")
+rc=$(echo "$out" | sed -n '1p'); f=$(echo "$out" | sed -n '2p')
+assert_exit "schedule exit" "0" "$rc"
+assert_contains "schedule output" '"security","privacy"' "$f"
+rm -f "$f"
+
+# 4. Invalid area -> rejected
+out=$(run_script "workflow_dispatch" "not-a-real-area")
+rc=$(echo "$out" | sed -n '1p'); f=$(echo "$out" | sed -n '2p')
+assert_exit "invalid-area exit" "1" "$rc"
+assert_file_empty "invalid-area output" "$f"
+rm -f "$f"
+
+# 5. Injection attempt -> rejected
+out=$(run_script "workflow_dispatch" $'security\nMALICIOUS=1')
+rc=$(echo "$out" | sed -n '1p'); f=$(echo "$out" | sed -n '2p')
+assert_exit "injection-attempt exit" "1" "$rc"
+assert_file_empty "injection-attempt output" "$f"
+rm -f "$f"
+
+echo "All resolve-review-area tests passed."
