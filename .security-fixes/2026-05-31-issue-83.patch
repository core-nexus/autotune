+name: scripts-ci
+
+# Runs shellcheck + unit tests for the workflow helper scripts. These scripts
+# enforce the trust boundaries that gate the privileged auto-fixer jobs, so
+# they must stay green.
+
+on:
+  pull_request:
+    paths:
+      - '.github/workflows/scripts/**'
+      - '.github/workflows/scripts-ci.yml'
+  push:
+    branches: [main]
+    paths:
+      - '.github/workflows/scripts/**'
+      - '.github/workflows/scripts-ci.yml'
+
+permissions:
+  contents: read
+
+jobs:
+  test-scripts:
+    runs-on: ubuntu-latest
+    timeout-minutes: 5
+    steps:
+      - name: Checkout repository
+        # Pinned to commit SHA — v4 currently resolves to v4.3.1.
+        uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5  # v4
+
+      - name: Shellcheck all scripts
+        run: |
+          shellcheck \
+            .github/workflows/scripts/*.sh \
+            .github/workflows/scripts/tests/*.sh
+
+      - name: Run trust-filter unit tests
+        run: bash .github/workflows/scripts/tests/test-priority-gate.sh
+
+      - name: Run resolve-review-area tests
+        run: bash .github/workflows/scripts/tests/test-resolve-review-area.sh
