@@ -1,19 +1,89 @@
 #!/usr/bin/env bash
 set -euo pipefail
 
-# Extract MAXIMUM_FIX_PRIORITY from the latest PR review comment.
+# Extract MAXIMUM_FIX_PRIORITY from the latest PR review comment authored by
+# a trusted bot/Apps actor — never from a human-authored or attacker-controlled
+# comment.
+#
+# Security context:
+#   The priority value gates whether the privileged auto-fixer runs. Treating
+#   arbitrary PR comments as the source of truth would let any commenter post
+#   "MAXIMUM_FIX_PRIORITY:HIGH" and force a fix run. We therefore restrict the
+#   source to comments authored by:
+#     - github-actions[bot]      (claude-code-action posts as this identity)
+#     - claude[bot]              (the Claude GitHub App identity)
+#   and additionally require the author type to be "Bot".
+#
+# Failure mode: any unexpected gh/API failure fails CLOSED (priority=NONE),
+# rather than silently defaulting in a way an attacker could exploit.
 #
 # Required env vars:
 #   GITHUB_OUTPUT
 #   GH_TOKEN
 #   REPO - GitHub repository (owner/repo)
 #   PR_NUMBER - the PR number
+#
+# Optional env vars:
+#   TRUSTED_COMMENT_AUTHORS - comma-separated list of trusted bot logins.
+#                             Defaults to the known review bot identities.
 
 : "${GITHUB_OUTPUT:?}" "${REPO:?}" "${PR_NUMBER:?}"
 
-PRIORITY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
-  --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' 2>/dev/null \
-  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || echo "NONE")
+TRUSTED_COMMENT_AUTHORS="${TRUSTED_COMMENT_AUTHORS:-github-actions[bot],claude[bot]}"
+
+# Build a JSON array of allowed logins for jq.
+ALLOWED_LOGINS_JSON="$(printf '%s' "${TRUSTED_COMMENT_AUTHORS}" \
+  | tr ',' '\n' \
+  | jq -R . \
+  | jq -s .)"
+
+# Capture stderr so genuine API failures are visible and distinguishable
+# from "no matching comment found". On API error we fail closed.
+TMP_ERR="$(mktemp)"
+trap 'rm -f "${TMP_ERR}"' EXIT
+
+LATEST_TRUSTED_COMMENT=""
+if ! LATEST_TRUSTED_COMMENT="$(gh api \
+      --paginate \
+      "repos/${REPO}/issues/${PR_NUMBER}/comments" \
+      --jq '.[]' 2>"${TMP_ERR}" \
+    | jq -s \
+        --argjson allowed "${ALLOWED_LOGINS_JSON}" \
+        '[.[]
+          | select(.user.type == "Bot")
+          | select(.user.login as $login | $allowed | index($login))
+          | select(.body | test("MAXIMUM_FIX_PRIORITY:"))
+         ]
+         | last
+         | (.body // "")')"; then
+  echo "::error::gh api call failed while fetching PR comments. Failing closed." >&2
+  echo "----- gh stderr -----" >&2
+  cat "${TMP_ERR}" >&2
+  echo "---------------------" >&2
+  echo "priority=NONE" >> "${GITHUB_OUTPUT}"
+  exit 0
+fi
+
+# A non-empty stderr alongside a zero exit (e.g. partial-page failure) is
+# treated as a hard error too — we'd rather skip a fix than run on poisoned data.
+if [[ -s "${TMP_ERR}" ]]; then
+  echo "::error::gh api emitted errors on stderr. Failing closed." >&2
+  echo "----- gh stderr -----" >&2
+  cat "${TMP_ERR}" >&2
+  echo "---------------------" >&2
+  echo "priority=NONE" >> "${GITHUB_OUTPUT}"
+  exit 0
+fi
+
+# jq emits the JSON string literal (including quotes) — strip them, then pull
+# the priority value out of the body text.
+LATEST_BODY="$(printf '%s' "${LATEST_TRUSTED_COMMENT}" | jq -r '.' 2>/dev/null || echo "")"
+PRIORITY="$(printf '%s' "${LATEST_BODY}" \
+  | grep -oE 'MAXIMUM_FIX_PRIORITY:[A-Z_]+' \
+  | tail -1 \
+  | cut -d: -f2 \
+  || true)"
+PRIORITY="${PRIORITY:-NONE}"
 
 echo "MAXIMUM_FIX_PRIORITY: ${PRIORITY}"
 echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
