diff --git a/.github/workflows/scripts/extract-pr-review-priority.sh b/.github/workflows/scripts/extract-pr-review-priority.sh
index c28572e..0460dca 100755
--- a/.github/workflows/scripts/extract-pr-review-priority.sh
+++ b/.github/workflows/scripts/extract-pr-review-priority.sh
@@ -8,12 +8,49 @@ set -euo pipefail
 #   GH_TOKEN
 #   REPO - GitHub repository (owner/repo)
 #   PR_NUMBER - the PR number
+#
+# AI-robustness controls (ai-compliance review):
+#   - Captured priority is validated against the allowed enum
+#     {NONE,XLOW,LOW,MEDIUM,HIGH}. An out-of-band value is failed loudly
+#     via ::warning:: and normalised to NONE so the write-access fixer
+#     does not run on an unrecognised gate value.
+#   - GitHub API call failures are surfaced via ::warning::, not silently
+#     collapsed to "no marker found".
 
 : "${GITHUB_OUTPUT:?}" "${REPO:?}" "${PR_NUMBER:?}"
 
-PRIORITY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
-  --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' 2>/dev/null \
-  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || echo "NONE")
+ALLOWED_PRIORITIES=(NONE XLOW LOW MEDIUM HIGH)
+
+is_allowed_priority() {
+  local value="$1"
+  local allowed
+  for allowed in "${ALLOWED_PRIORITIES[@]}"; do
+    if [[ "${value}" = "${allowed}" ]]; then
+      return 0
+    fi
+  done
+  return 1
+}
+
+API_ERR=$(mktemp)
+COMMENT_BODY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
+  --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' 2>"${API_ERR}") || API_RC=$?
+API_RC="${API_RC:-0}"
+if [[ "${API_RC}" -ne 0 ]]; then
+  echo "::warning::gh api call for PR ${PR_NUMBER} comments failed (rc=${API_RC}): $(tr '\n' ' ' < "${API_ERR}")"
+  COMMENT_BODY=""
+fi
+rm -f "${API_ERR}"
+
+PRIORITY=$(echo "${COMMENT_BODY}" \
+  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' \
+  | tail -1 || true)
+
+PRIORITY="${PRIORITY:-NONE}"
+if ! is_allowed_priority "${PRIORITY}"; then
+  echo "::warning::MAXIMUM_FIX_PRIORITY value '${PRIORITY}' is not in allowed enum {NONE,XLOW,LOW,MEDIUM,HIGH} for PR ${PR_NUMBER}; normalising to NONE"
+  PRIORITY="NONE"
+fi
 
 echo "MAXIMUM_FIX_PRIORITY: ${PRIORITY}"
 echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
