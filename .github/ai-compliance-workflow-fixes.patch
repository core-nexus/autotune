diff --git a/.github/workflows/scripts/extract-pr-review-priority.sh b/.github/workflows/scripts/extract-pr-review-priority.sh
index c28572e..1408334 100755
--- a/.github/workflows/scripts/extract-pr-review-priority.sh
+++ b/.github/workflows/scripts/extract-pr-review-priority.sh
@@ -11,9 +11,26 @@ set -euo pipefail
 
 : "${GITHUB_OUTPUT:?}" "${REPO:?}" "${PR_NUMBER:?}"
 
+# Note: do NOT use `|| echo "NONE"` as a fallback here. A failed API call or a
+# review comment that never emitted a parseable token would then be silently
+# treated as "clean" (fail open), skipping the fix stage and dropping real
+# findings. Capture the raw result and validate it explicitly below.
 PRIORITY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
   --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' 2>/dev/null \
-  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || echo "NONE")
+  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || true)
 
-echo "MAXIMUM_FIX_PRIORITY: ${PRIORITY}"
-echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
+# Fail safe, not fail open. Only a recognized priority value is trusted; anything
+# else (no comment found, truncated/garbled output, format drift) becomes a
+# distinct UNKNOWN sentinel and fails the job LOUDLY so a broken AI review is
+# surfaced as a red check rather than masquerading as a clean one.
+case "${PRIORITY}" in
+  NONE | XLOW | LOW | MEDIUM | HIGH)
+    echo "MAXIMUM_FIX_PRIORITY: ${PRIORITY}"
+    echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
+    ;;
+  *)
+    echo "priority=UNKNOWN" >> "${GITHUB_OUTPUT}"
+    echo "::error title=Review priority unparseable::Could not extract a valid MAXIMUM_FIX_PRIORITY from the review of PR #${PR_NUMBER} (got '${PRIORITY:-<empty>}'). The AI review output is missing or malformed; failing so the failure is surfaced rather than masked."
+    exit 1
+    ;;
+esac
