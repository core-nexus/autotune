 fi
 
-PRIORITY="${PRIORITY:-NONE}"
-echo "MAXIMUM_FIX_PRIORITY for ${REVIEW_AREA}: ${PRIORITY}"
-echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
+# Fail safe, not fail open. A parseable priority must be one of the known
+# values. If nothing parsed (truncated/garbled AI output, format drift) or the
+# token is unrecognized, emit a distinct UNKNOWN sentinel and fail the job
+# LOUDLY rather than silently defaulting to NONE — a broken AI run must never be
+# indistinguishable from a genuinely clean review (that would silently drop real
+# findings, the most dangerous failure mode for an automated safety gate).
+case "${PRIORITY}" in
+  NONE | XLOW | LOW | MEDIUM | HIGH)
+    echo "MAXIMUM_FIX_PRIORITY for ${REVIEW_AREA}: ${PRIORITY}"
+    echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
+    ;;
+  *)
+    echo "priority=UNKNOWN" >> "${GITHUB_OUTPUT}"
+    echo "::error title=Review priority unparseable::Could not extract a valid MAXIMUM_FIX_PRIORITY for '${REVIEW_AREA}' (got '${PRIORITY:-<empty>}'). The AI review output is missing or malformed; treating as UNKNOWN and failing so the failure is surfaced rather than masked."
+    exit 1
+    ;;
+esac
