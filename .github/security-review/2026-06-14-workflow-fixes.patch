diff --git a/.github/workflows/scripts/extract-pr-review-priority.sh b/.github/workflows/scripts/extract-pr-review-priority.sh
index c28572e..2ac712a 100755
--- a/.github/workflows/scripts/extract-pr-review-priority.sh
+++ b/.github/workflows/scripts/extract-pr-review-priority.sh
@@ -3,17 +3,49 @@ set -euo pipefail
 
 # Extract MAXIMUM_FIX_PRIORITY from the latest PR review comment.
 #
+# SECURITY: the priority gate decides whether the privileged, write-enabled
+# fix stage runs, so it must only ever read TRUSTED comments. We therefore
+# only consider comments authored by a bot/GitHub App (type == "Bot"), which
+# is where the review action posts its verdict. A human collaborator can't set
+# their comment's user type to "Bot", so an outside user cannot post
+# `MAXIMUM_FIX_PRIORITY:HIGH` to force a fix run (or `NONE` to suppress one).
+# Optionally pin further to a single login via REVIEW_BOT_LOGIN.
+#
 # Required env vars:
 #   GITHUB_OUTPUT
 #   GH_TOKEN
 #   REPO - GitHub repository (owner/repo)
 #   PR_NUMBER - the PR number
+#
+# Optional env vars:
+#   REVIEW_BOT_LOGIN - if set, only comments from this exact login are trusted
 
 : "${GITHUB_OUTPUT:?}" "${REPO:?}" "${PR_NUMBER:?}"
 
-PRIORITY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
-  --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' 2>/dev/null \
-  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || echo "NONE")
+# Only trust comments from a bot/App; optionally restrict to one login.
+JQ_FILTER='[.[]
+  | select(.user.type == "Bot")
+  | select(env.REVIEW_BOT_LOGIN == null or env.REVIEW_BOT_LOGIN == "" or .user.login == env.REVIEW_BOT_LOGIN)
+  | select(.body | test("MAXIMUM_FIX_PRIORITY:"))]
+  | last | .body // ""'
+
+# Capture stderr so genuine gh/API failures are surfaced, not masked as "no
+# match". A real failure must fail closed (set -e aborts) rather than silently
+# producing NONE.
+ERR_LOG=$(mktemp)
+trap 'rm -f "${ERR_LOG}"' EXIT
+
+if ! COMMENT_BODY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
+  --jq "${JQ_FILTER}" 2>"${ERR_LOG}"); then
+  echo "::error::Failed to fetch PR comments for ${REPO} PR ${PR_NUMBER}" >&2
+  cat "${ERR_LOG}" >&2
+  exit 1
+fi
+
+PRIORITY=$(printf '%s' "${COMMENT_BODY}" \
+  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' \
+  | tail -1 || true)
+PRIORITY="${PRIORITY:-NONE}"
 
 echo "MAXIMUM_FIX_PRIORITY: ${PRIORITY}"
 echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
