+            `> _Generated by Claude (model: claude-opus-4-7) via the automated PR-review workflow. AI-authored — review critically; it may contain errors or hallucinations._`
+
             Do NOT prefix numbers with `#` (GitHub treats that as issue links).
             For each item, reference the file and line. Prioritize by severity.
 
@@ -135,14 +143,23 @@ jobs:
   # ─── Stage 2: Fix (only if review found issues worth fixing) ────────────────
   fix-review-issues:
     needs: review
-    # Run after review if priority is LOW/MEDIUM/HIGH, or directly on "/claude-fix"
+    # Run after review if priority is LOW/MEDIUM/HIGH, or directly on a
+    # "/claude-fix" comment from a user with write/maintain access
+    # (author_association gate prevents untrusted actors from triggering
