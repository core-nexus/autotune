new file mode 100755
index 0000000..aae432f
--- /dev/null
+++ b/.github/workflows/scripts/tests/collect-fix-areas.test.sh
@@ -0,0 +1,93 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+# Unit tests for collect-fix-areas.sh — the script that turns per-area review
+# priority artifacts into the fix-job matrix. This guards the core behaviour
+# that prevents fanning out a paid Opus fix session for every review area:
+# only HIGH/MEDIUM areas must appear in the emitted matrix.
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+COLLECT="${SCRIPT_DIR}/collect-fix-areas.sh"
+
+WORKDIR="$(mktemp -d)"
+trap 'rm -rf "${WORKDIR}"' EXIT
+
+failures=0
+
+# Create a downloaded-artifact layout: priorities/priority-<area>/priority.txt
+# $1 = priorities dir, then pairs of <area> <priority>.
+make_priorities() {
+  local dir="$1"; shift
+  rm -rf "${dir}"
+  while [[ $# -gt 0 ]]; do
+    local area="$1" prio="$2"; shift 2
+    mkdir -p "${dir}/priority-${area}"
+    printf '%s\n' "${prio}" > "${dir}/priority-${area}/priority.txt"
+  done
+}
+
+# Run collect-fix-areas.sh against a priorities dir and echo fix_areas_json.
+run_collect() {
+  local priorities_dir="$1"
+  local out_file
+  out_file="$(mktemp "${WORKDIR}/output.XXXXXX")"
+  GITHUB_OUTPUT="${out_file}" PRIORITIES_DIR="${priorities_dir}" bash "${COLLECT}" >/dev/null
+  grep -oP '^fix_areas_json=\K.*' "${out_file}"
+}
+
+assert_eq() {
+  local name="$1" expected="$2" actual="$3"
+  if [[ "${expected}" == "${actual}" ]]; then
+    echo "ok   - ${name}"
+  else
+    echo "FAIL - ${name}"
+    echo "         expected: ${expected}"
+    echo "         actual:   ${actual}"
+    failures=$((failures + 1))
+  fi
+}
+
+# 1. Only HIGH/MEDIUM areas are included; LOW/XLOW/NONE are excluded.
+make_priorities "${WORKDIR}/p1" \
+  security HIGH \
+  performance MEDIUM \
+  documentation LOW \
+  testing NONE \
+  privacy XLOW
+got="$(run_collect "${WORKDIR}/p1")"
+# Areas are emitted in shell-glob (sorted) order: performance, security.
+assert_eq "filters to HIGH/MEDIUM only" \
+  '[{"area":"performance","priority":"MEDIUM"},{"area":"security","priority":"HIGH"}]' \
+  "${got}"
+
+# 2. No actionable areas -> empty JSON array (fix job is skipped).
+make_priorities "${WORKDIR}/p2" \
+  documentation LOW \
+  testing NONE
+got="$(run_collect "${WORKDIR}/p2")"
+assert_eq "empty array when nothing actionable" '[]' "${got}"
+
+# 3. Completely empty priorities dir -> empty JSON array.
+mkdir -p "${WORKDIR}/p3"
+got="$(run_collect "${WORKDIR}/p3")"
+assert_eq "empty array when no artifacts" '[]' "${got}"
+
+# 4. Whitespace/newlines around the value are tolerated.
+make_priorities "${WORKDIR}/p4" correctness MEDIUM
+printf '  HIGH \n' > "${WORKDIR}/p4/priority-correctness/priority.txt"
+got="$(run_collect "${WORKDIR}/p4")"
+assert_eq "trims surrounding whitespace" \
+  '[{"area":"correctness","priority":"HIGH"}]' "${got}"
+
+# 5. A missing priority.txt for an area is skipped, not fatal.
+make_priorities "${WORKDIR}/p5" code-quality HIGH
+mkdir -p "${WORKDIR}/p5/priority-empty-area"
+got="$(run_collect "${WORKDIR}/p5")"
+assert_eq "skips artifact missing priority.txt" \
+  '[{"area":"code-quality","priority":"HIGH"}]' "${got}"
+
+if [[ "${failures}" -gt 0 ]]; then
+  echo "${failures} test(s) failed"
+  exit 1
+fi
+echo "All collect-fix-areas tests passed"
