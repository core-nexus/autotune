@@ -0,0 +1,49 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+# Build the fix-job matrix from per-area review priorities.
+#
+# Each review matrix leg uploads an artifact named "priority-<area>" containing
+# a single file "priority.txt" with that area's MAXIMUM_FIX_PRIORITY value.
+# Those artifacts are downloaded into PRIORITIES_DIR as:
+#
+#   ${PRIORITIES_DIR}/priority-<area>/priority.txt
+#
+# This script emits a JSON array of {"area","priority"} objects for every area
+# whose priority is HIGH or MEDIUM. The fix job uses it as `matrix.include`, so
+# a (paid) Opus fix session is launched ONLY for areas with actionable
+# findings — instead of all areas, which is what the previous single,
+# last-writer-wins matrix output caused.
+#
+# Required env vars:
+#   GITHUB_OUTPUT
+#   PRIORITIES_DIR - directory containing the downloaded priority-* artifacts
+
+: "${GITHUB_OUTPUT:?}" "${PRIORITIES_DIR:?}"
+
+entries=()
+
+shopt -s nullglob
+for dir in "${PRIORITIES_DIR}"/priority-*/; do
+  area="$(basename "${dir}")"
+  area="${area#priority-}"
+  file="${dir}priority.txt"
+
+  if [[ ! -f "${file}" ]]; then
+    echo "Area ${area}: <no priority.txt>"
+    continue
+  fi
+
+  priority="$(tr -d '[:space:]' < "${file}")"
+  echo "Area ${area}: ${priority:-<empty>}"
+
+  if [[ "${priority}" == "HIGH" || "${priority}" == "MEDIUM" ]]; then
+    entries+=("{\"area\":\"${area}\",\"priority\":\"${priority}\"}")
+  fi
+done
+
+# Join the entries into a compact JSON array (empty -> []).
+json="[$(IFS=,; echo "${entries[*]:-}")]"
+
+echo "fix_areas_json=${json}" >> "${GITHUB_OUTPUT}"
+echo "Areas needing fixes: ${json}"
