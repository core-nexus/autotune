@@ -0,0 +1,63 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+# Unit tests for priority-lib.sh (validate_priority).
+# Run directly: .github/workflows/scripts/lib/priority-lib.test.sh
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+# shellcheck source=.github/workflows/scripts/lib/priority-lib.sh
+source "${SCRIPT_DIR}/priority-lib.sh"
+
+failures=0
+
+assert_eq() {
+  local desc="$1" expected="$2" actual="$3"
+  if [[ "${expected}" == "${actual}" ]]; then
+    echo "ok   - ${desc}"
+  else
+    echo "FAIL - ${desc}: expected '${expected}', got '${actual}'"
+    failures=$((failures + 1))
+  fi
+}
+
+# Valid enum values pass through unchanged (stderr discarded).
+for v in NONE XLOW LOW MEDIUM HIGH; do
+  assert_eq "valid '${v}' passes through" "${v}" "$(validate_priority "${v}" 2>/dev/null)"
+done
+
+# Invalid / hallucinated / malformed values fail safe to NONE.
+assert_eq "hallucinated 'CRITICAL' -> NONE" "NONE" "$(validate_priority "CRITICAL" 2>/dev/null)"
+assert_eq "empty string -> NONE"            "NONE" "$(validate_priority "" 2>/dev/null)"
+assert_eq "garbage token -> NONE"           "NONE" "$(validate_priority "FOO_BAR" 2>/dev/null)"
+assert_eq "lowercase 'medium' -> NONE"      "NONE" "$(validate_priority "medium" 2>/dev/null)"
+assert_eq "missing argument -> NONE"        "NONE" "$(validate_priority 2>/dev/null)"
+
+# A warning is emitted on a NON-EMPTY invalid token (stderr only).
+if validate_priority "CRITICAL" 2>&1 1>/dev/null | grep -q "::warning::"; then
+  echo "ok   - emits ::warning:: on invalid non-empty token"
+else
+  echo "FAIL - no ::warning:: emitted on invalid non-empty token"
+  failures=$((failures + 1))
+fi
+
+# No warning is emitted on a valid token.
+if [[ -z "$(validate_priority "HIGH" 2>&1 1>/dev/null)" ]]; then
+  echo "ok   - no warning on valid token"
+else
+  echo "FAIL - unexpected warning on valid token"
+  failures=$((failures + 1))
+fi
+
+# No warning on an EMPTY value (legitimate "no marker / clean review" state).
+if [[ -z "$(validate_priority "" 2>&1 1>/dev/null)" ]]; then
+  echo "ok   - no warning on empty value (clean-review state)"
+else
+  echo "FAIL - unexpected warning on empty value"
+  failures=$((failures + 1))
+fi
+
+if [[ "${failures}" -ne 0 ]]; then
+  echo "${failures} test(s) failed"
+  exit 1
+fi
+echo "All priority-lib tests passed"
