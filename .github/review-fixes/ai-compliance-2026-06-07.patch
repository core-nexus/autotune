+name: Scripts Tests
+
+# Lint and unit-test the pipeline's shell scripts. These scripts gate the
+# autonomous write-access fix stage, so their behavior is verified in CI.
+
+on:
+  pull_request:
+    paths:
+      - '.github/workflows/scripts/**'
+      - '.github/workflows/scripts-test.yml'
+  push:
+    branches: [main]
+    paths:
+      - '.github/workflows/scripts/**'
+      - '.github/workflows/scripts-test.yml'
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+jobs:
+  test:
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout repository
+        uses: actions/checkout@v4
+
+      - name: Run shellcheck
+        run: shellcheck .github/workflows/scripts/*.sh .github/workflows/scripts/lib/*.sh
+
+      - name: Run priority-lib unit tests
+        run: bash .github/workflows/scripts/lib/priority-lib.test.sh
