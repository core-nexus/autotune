index 0000000..253183e
--- /dev/null
+++ b/.github/workflows/scripts/lib/priority-lib.sh
@@ -0,0 +1,39 @@
+#!/usr/bin/env bash
+# Shared helpers for review-priority extraction.
+#
+# This library centralizes the MAXIMUM_FIX_PRIORITY enum and validation so the
+# value emitted by the AI review is checked against the allowed set BEFORE it is
+# used to gate the write-access fix stage. The AI emits free text; a hallucinated
+# or malformed token (e.g. "CRITICAL", "medium", "FOO") must never silently
+# trigger — or block — automation.
+
+# Allowed MAXIMUM_FIX_PRIORITY enum values (must match the review prompts).
+VALID_PRIORITIES=("NONE" "XLOW" "LOW" "MEDIUM" "HIGH")
+
+# validate_priority <value>
+#
+# Echoes <value> on stdout if it is one of the allowed enum values, otherwise
+# echoes "NONE".
+#
+# An EMPTY value is a legitimate "no marker found / clean review" state and maps
+# to NONE silently. A NON-EMPTY value that is not in the enum (a hallucinated or
+# malformed token such as "CRITICAL" or "medium") maps to NONE and emits a
+# GitHub Actions ::warning:: on stderr so the anomaly is visible.
+#
+# Fails safe toward inaction: an unexpected value maps to NONE (no auto-fix)
+# rather than being acted on. Never returns non-zero, so callers using
+# `set -euo pipefail` are not aborted by an unrecognized token.
+validate_priority() {
+  local value="${1:-}"
+  local valid
+  for valid in "${VALID_PRIORITIES[@]}"; do
+    if [[ "${value}" == "${valid}" ]]; then
+      echo "${value}"
+      return 0
+    fi
+  done
+  if [[ -n "${value}" ]]; then
+    echo "::warning::Unrecognized MAXIMUM_FIX_PRIORITY token '${value}' — expected one of ${VALID_PRIORITIES[*]}; defaulting to NONE (no auto-fix)." >&2
+  fi
+  echo "NONE"
+}
