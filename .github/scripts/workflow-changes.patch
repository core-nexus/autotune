diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml
new file mode 100644
index 0000000..dd60eab
--- /dev/null
+++ b/.github/workflows/ci.yml
@@ -0,0 +1,24 @@
+name: CI
+
+# Lint and test the review helper scripts. Runs on PRs and pushes to main, and
+# is workflow_dispatch-able so the fix stage's trigger-ci-workflows.sh can kick
+# it off on a review branch.
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+  workflow_dispatch:
+
+jobs:
+  shell:
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout repository
+        uses: actions/checkout@v4
+
+      - name: ShellCheck helper scripts
+        run: shellcheck .github/scripts/*.sh .github/scripts/tests/*.sh
+
+      - name: Run script tests
+        run: .github/scripts/tests/run-tests.sh
