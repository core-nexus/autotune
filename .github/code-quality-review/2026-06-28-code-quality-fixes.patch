-    2>/dev/null || true)
-  PRIORITY=$(echo "${BODY}" \
-    | grep -oP 'MAXIMUM_FIX_PRIORITY:\K[A-Z_]+' || true)
+    --jq "[.[] | select(.title | startswith(\"review(${REVIEW_AREA})\"))] | .[0].body"); then
+    echo "::error::Failed to list issues for ${REPO} (gh issue list error)." >&2
+    exit 1
