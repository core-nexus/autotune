+on:
+  push:
+    branches: [main]
+  pull_request:
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+jobs:
+  lint:
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout repository
+        uses: actions/checkout@v4
+
+      - name: ShellCheck scripts
+        run: shellcheck .github/workflows/scripts/*.sh
+
+      - name: Bash syntax check
+        run: |
+          for f in .github/workflows/scripts/*.sh; do
+            bash -n "$f"
+          done
+
