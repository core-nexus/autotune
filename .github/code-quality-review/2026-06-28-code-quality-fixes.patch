diff --git a/.github/workflows/scripts/check-review-areas-in-sync.sh b/.github/workflows/scripts/check-review-areas-in-sync.sh
new file mode 100755
index 0000000..f43b14d
--- /dev/null
+++ b/.github/workflows/scripts/check-review-areas-in-sync.sh
@@ -0,0 +1,40 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+# Guard against drift between the two places the review-area list lives:
+#   1. ALL_AREAS in resolve-review-area.sh (canonical, used by the schedule)
+#   2. the workflow_dispatch `review_area` dropdown in codebase-review.yml
+#
+# The dropdown must be static YAML (it cannot call the script), so the
+# duplication is structural — this check makes the duplication safe by failing
+# loud if the two ever disagree. The dropdown carries one extra "all" sentinel
+# that is intentionally not part of the canonical set.
+#
+# No required env vars; resolves paths relative to this script.
+
+ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
+SCRIPT="${ROOT}/.github/workflows/scripts/resolve-review-area.sh"
+WORKFLOW="${ROOT}/.github/workflows/codebase-review.yml"
+
+# 1. Areas declared in the script's ALL_AREAS JSON array.
+script_areas=$(grep -oP "ALL_AREAS='\K[^']+" "${SCRIPT}" \
+  | grep -oP '"[a-z][a-z-]*"' | tr -d '"' | sort)
+
+# 2. Dropdown options, minus the trailing "all" sentinel.
+dropdown_areas=$(awk '
+  /^[[:space:]]*options:/ { inopts=1; next }
+  inopts && /^[[:space:]]*-[[:space:]]/ { sub(/^[[:space:]]*-[[:space:]]*/, ""); print; next }
+  inopts && !/^[[:space:]]*#/ { exit }
+' "${WORKFLOW}" | grep -vx 'all' | sort)
+
+if [[ "${script_areas}" != "${dropdown_areas}" ]]; then
+  echo "::error::Review-area lists are out of sync between:" >&2
+  echo "  - ${SCRIPT} (ALL_AREAS)" >&2
+  echo "  - ${WORKFLOW} (workflow_dispatch options)" >&2
+  echo "--- diff (< script  > dropdown) ---" >&2
+  diff <(echo "${script_areas}") <(echo "${dropdown_areas}") >&2 || true
+  exit 1
+fi
+
+count=$(echo "${script_areas}" | grep -c .)
+echo "Review-area lists are in sync (${count} areas): $(echo "${script_areas}" | tr '\n' ' ')"
diff --git a/.github/workflows/scripts/extract-pr-review-priority.sh b/.github/workflows/scripts/extract-pr-review-priority.sh
index c28572e..9136876 100755
--- a/.github/workflows/scripts/extract-pr-review-priority.sh
+++ b/.github/workflows/scripts/extract-pr-review-priority.sh
@@ -9,11 +9,22 @@ set -euo pipefail
 #   REPO - GitHub repository (owner/repo)
 #   PR_NUMBER - the PR number
 
-: "${GITHUB_OUTPUT:?}" "${REPO:?}" "${PR_NUMBER:?}"
+: "${GITHUB_OUTPUT:?}" "${GH_TOKEN:?}" "${REPO:?}" "${PR_NUMBER:?}"
 
-PRIORITY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
-  --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' 2>/dev/null \
-  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || echo "NONE")
+# Fetch the latest PR comment that carries a MAXIMUM_FIX_PRIORITY token.
+# Fail loud on a genuine API error instead of masking it as "no findings": a
+# swallowed failure here resolves to NONE and silently skips the fix stage.
+if ! COMMENT_BODY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
+  --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body'); then
+  echo "::error::Failed to fetch comments for ${REPO} item ${PR_NUMBER} (gh api error)." >&2
+  exit 1
+fi
+
+# Collapse any extra matches to a single line (matching extract-review-priority.sh).
+# A multi-line value would corrupt the GITHUB_OUTPUT and mis-trigger the fix gate.
+PRIORITY=$(printf '%s\n' "${COMMENT_BODY}" \
+  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' | tail -1 || true)
+PRIORITY="${PRIORITY:-NONE}"
 
 echo "MAXIMUM_FIX_PRIORITY: ${PRIORITY}"
 echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
