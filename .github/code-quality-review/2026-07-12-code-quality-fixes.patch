@@ -12,11 +12,31 @@ set -euo pipefail
 
 : "${GITHUB_OUTPUT:?}" "${EVENT_NAME:?}"
 
-ALL_AREAS='["security","privacy","compliance","ai-compliance","error-handling","code-quality","performance","testing","documentation","dependency-health","correctness","e-commerce"]'
+# Single source of truth for the area list: the review-prompt files under
+# .github/review-prompts/. Adding or removing a prompt file automatically
+# changes the areas this workflow runs. NOTE: the workflow_dispatch `options:`
+# list in codebase-review.yml must be kept in sync with these filenames by hand
+# — GitHub Actions cannot populate `choice` options dynamically.
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+PROMPTS_DIR="${SCRIPT_DIR}/../../review-prompts"
 
-if [[ "${EVENT_NAME}" = "workflow_dispatch" ]]; then
-  AREA="${INPUT_REVIEW_AREA:-security}"
-  if [[ "${AREA}" = "all" ]]; then
+ALL_AREAS="$(find "${PROMPTS_DIR}" -maxdepth 1 -name '*.md' -printf '%f\n' 2>/dev/null \
+  | sed 's/\.md$//' \
+  | sort \
+  | jq -R . \
+  | jq -cs .)"
+
+# Defensive fallback: if the prompt directory could not be read (missing dir or
+# no jq available), fall back to the known list so the workflow still runs.
+if [[ -z "${ALL_AREAS}" || "${ALL_AREAS}" == "[]" ]]; then
+  ALL_AREAS='["security","privacy","compliance","ai-compliance","error-handling","code-quality","performance","testing","documentation","dependency-health","correctness","e-commerce"]'
+fi
+
+if [[ "${EVENT_NAME}" == "workflow_dispatch" ]]; then
+  # review_area is a required `choice` input, so INPUT_REVIEW_AREA is always set
+  # on this path; the :- default is only a defensive guard.
+  AREA="${INPUT_REVIEW_AREA:-all}"
+  if [[ "${AREA}" == "all" ]]; then
     echo "areas_json=${ALL_AREAS}" >> "${GITHUB_OUTPUT}"
   else
     echo "areas_json=[\"${AREA}\"]" >> "${GITHUB_OUTPUT}"
