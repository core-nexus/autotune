-# Method 2 (fallback): list recent issues via REST API
+# Method 2 (fallback): list recent issues via REST API.
+#
+# SECURITY: this gate decides whether the privileged fix job (contents: write)
+# runs. On a public repo, anyone can open an issue titled "review(<area>): ..."
+# whose body contains "MAXIMUM_FIX_PRIORITY:HIGH". To prevent attacker-controlled
+# issue content from coercing the fixer, we ONLY trust issues authored by a bot
+# identity (the review stage runs as a bot, e.g. github-actions[bot] or the app's
+# bot login). Issues authored by regular users are ignored. If no trusted issue
+# is found, we fail closed (PRIORITY stays empty -> NONE -> fix job does not run).
 if [[ -z "${PRIORITY}" ]]; then
-  echo "Falling back to gh issue list..."
+  echo "Falling back to gh issue list (bot-authored issues only)..."
   BODY=$(gh issue list \
     --repo "${REPO}" \
     --state all --limit 10 \
-    --json title,body \
-    --jq "[.[] | select(.title | startswith(\"review(${REVIEW_AREA})\"))] | .[0].body" \
+    --json title,body,author \
+    --jq "[.[] | select(.title | startswith(\"review(${REVIEW_AREA})\")) | select(.author.login | endswith(\"[bot]\"))] | .[0].body" \
     2>/dev/null || true)
   PRIORITY=$(echo "${BODY}" \
     | grep -oP 'MAXIMUM_FIX_PRIORITY:\K[A-Z_]+' || true)
   echo "Extracted from issue list: ${PRIORITY:-<empty>}"
 fi
 
+# Fail closed: any unresolved / unexpected state is treated as NONE so the
+# privileged fix job does not run unless a trusted source set a real priority.
 PRIORITY="${PRIORITY:-NONE}"
 echo "MAXIMUM_FIX_PRIORITY for ${REVIEW_AREA}: ${PRIORITY}"
 echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
