diff --git a/.github/workflows/scripts-test.yml b/.github/workflows/scripts-test.yml
new file mode 100644
index 0000000..3c86a39
--- /dev/null
+++ b/.github/workflows/scripts-test.yml
@@ -0,0 +1,31 @@
+name: Script Tests
+
+# Lint and test the helper scripts under .github/workflows/scripts.
+# Keeps the priority-extraction logic (and its fail-loud behavior on malformed
+# AI output) covered so a regression is caught before it ships.
+
+on:
+  push:
+    paths:
+      - '.github/workflows/scripts/**'
+      - '.github/workflows/scripts-test.yml'
+  pull_request:
+    paths:
+      - '.github/workflows/scripts/**'
+      - '.github/workflows/scripts-test.yml'
+
+permissions:
+  contents: read
+
+jobs:
+  test:
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout repository
+        uses: actions/checkout@v4
+
+      - name: Shellcheck scripts
+        run: shellcheck .github/workflows/scripts/*.sh .github/workflows/scripts/tests/*.sh
+
+      - name: Run script tests
+        run: .github/workflows/scripts/tests/test-extract-priority.sh
