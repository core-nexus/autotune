diff --git a/.github/workflows/scripts/tests/test-extract-priority.sh b/.github/workflows/scripts/tests/test-extract-priority.sh
new file mode 100755
index 0000000..8d904b9
--- /dev/null
+++ b/.github/workflows/scripts/tests/test-extract-priority.sh
@@ -0,0 +1,137 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+# Tests for the priority-extraction scripts, focused on the distinction between
+# "the review explicitly reported NONE" and "we failed to parse a verdict"
+# (which must emit a ::warning:: rather than silently coercing to NONE).
+#
+# Run: .github/workflows/scripts/tests/test-extract-priority.sh
+#
+# No network / no real `gh` needed: a stub `gh` is placed on PATH per-case.
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+EXTRACT_REVIEW="${SCRIPT_DIR}/extract-review-priority.sh"
+EXTRACT_PR="${SCRIPT_DIR}/extract-pr-review-priority.sh"
+
+WORK="$(mktemp -d)"
+trap 'rm -rf "${WORK}"' EXIT
+
+PASS=0
+FAIL=0
+
+# make_gh <stdout-string> — write a stub `gh` that ignores args and prints the
+# given string on stdout, then return its containing dir (for prepending to PATH).
+make_gh() {
+  local out="$1" dir
+  dir="$(mktemp -d)"
+  cat > "${dir}/gh" <<EOF
+#!/usr/bin/env bash
+printf '%s' '${out}'
+EOF
+  chmod +x "${dir}/gh"
+  printf '%s' "${dir}"
+}
+
+# run_review <execution-file-content|"__none__"> <gh-stdout> -> "priority|output"
+# `output` is the script's combined stdout+stderr — GitHub Actions `::warning::`
+# workflow commands are written to stdout, so the assertions look there.
+run_review() {
+  local file_content="$1" gh_out="$2"
+  local out_file exec_file log_file gh_dir
+  out_file="$(mktemp)"; log_file="$(mktemp)"
+  gh_dir="$(make_gh "${gh_out}")"
+
+  local exec_arg=""
+  if [[ "${file_content}" != "__none__" ]]; then
+    exec_file="$(mktemp)"
+    printf '%s' "${file_content}" > "${exec_file}"
+    exec_arg="${exec_file}"
+  fi
+
+  GITHUB_OUTPUT="${out_file}" REVIEW_AREA="testarea" REPO="owner/repo" \
+    EXECUTION_FILE="${exec_arg}" GH_TOKEN="x" \
+    PATH="${gh_dir}:${PATH}" \
+    bash "${EXTRACT_REVIEW}" > "${log_file}" 2>&1
+
+  local priority
+  priority="$(grep -oP '(?<=priority=).*' "${out_file}" || true)"
+  printf '%s|%s' "${priority}" "$(cat "${log_file}")"
+}
+
+# run_pr <gh-stdout> -> prints "priority|stdout"
+run_pr() {
+  local gh_out="$1"
+  local out_file stdout_file gh_dir
+  out_file="$(mktemp)"; stdout_file="$(mktemp)"
+  gh_dir="$(make_gh "${gh_out}")"
+
+  GITHUB_OUTPUT="${out_file}" REPO="owner/repo" PR_NUMBER="42" GH_TOKEN="x" \
+    PATH="${gh_dir}:${PATH}" \
+    bash "${EXTRACT_PR}" > "${stdout_file}" 2>&1
+
+  local priority
+  priority="$(grep -oP '(?<=priority=).*' "${out_file}" || true)"
+  printf '%s|%s' "${priority}" "$(cat "${stdout_file}")"
+}
+
+assert() {
+  local name="$1" cond="$2"
+  if [[ "${cond}" == "1" ]]; then
+    echo "  PASS: ${name}"; PASS=$((PASS + 1))
+  else
+    echo "  FAIL: ${name}"; FAIL=$((FAIL + 1))
+  fi
+}
+
+echo "extract-review-priority.sh"
+
+# 1. Explicit NONE in execution file -> NONE, and NOT flagged as a parse failure.
+res="$(run_review 'blah blah
+MAXIMUM_FIX_PRIORITY:NONE' '')"
+prio="${res%%|*}"; err="${res#*|}"
+assert "explicit NONE -> priority NONE" "$([[ "${prio}" == "NONE" ]] && echo 1 || echo 0)"
+assert "explicit NONE -> no ::warning::" "$([[ "${err}" != *"::warning::"* ]] && echo 1 || echo 0)"
+
+# 2. Real HIGH finding is preserved.
+res="$(run_review 'findings...
+MAXIMUM_FIX_PRIORITY:HIGH' '')"
+prio="${res%%|*}"
+assert "explicit HIGH -> priority HIGH" "$([[ "${prio}" == "HIGH" ]] && echo 1 || echo 0)"
+
+# 3. Non-empty output with NO marker, and empty fallback -> NONE WITH warning.
+res="$(run_review 'the model produced some prose but forgot the marker line' '')"
+prio="${res%%|*}"; err="${res#*|}"
+assert "malformed output -> priority NONE" "$([[ "${prio}" == "NONE" ]] && echo 1 || echo 0)"
+assert "malformed output -> emits ::warning::" "$([[ "${err}" == *"::warning::"* ]] && echo 1 || echo 0)"
+
+# 4. No execution file, fallback issue body carries a marker -> parsed from fallback.
+res="$(run_review '__none__' 'issue body
+MAXIMUM_FIX_PRIORITY:MEDIUM')"
+prio="${res%%|*}"; err="${res#*|}"
+assert "fallback MEDIUM -> priority MEDIUM" "$([[ "${prio}" == "MEDIUM" ]] && echo 1 || echo 0)"
+assert "fallback MEDIUM -> no ::warning::" "$([[ "${err}" != *"::warning::"* ]] && echo 1 || echo 0)"
+
+echo "extract-pr-review-priority.sh"
+
+# 5. Comment carries explicit NONE -> NONE, no warning.
+res="$(run_pr 'PR looks good
+MAXIMUM_FIX_PRIORITY:NONE')"
+prio="${res%%|*}"; out="${res#*|}"
+assert "PR explicit NONE -> priority NONE" "$([[ "${prio}" == "NONE" ]] && echo 1 || echo 0)"
+assert "PR explicit NONE -> no ::warning::" "$([[ "${out}" != *"::warning::"* ]] && echo 1 || echo 0)"
+
+# 6. Comment carries HIGH -> HIGH.
+res="$(run_pr 'issues found
+MAXIMUM_FIX_PRIORITY:HIGH')"
+prio="${res%%|*}"
+assert "PR HIGH -> priority HIGH" "$([[ "${prio}" == "HIGH" ]] && echo 1 || echo 0)"
+
+# 7. No parseable marker (empty/malformed API response) -> NONE WITH warning.
+res="$(run_pr '')"
+prio="${res%%|*}"; out="${res#*|}"
+assert "PR no marker -> priority NONE" "$([[ "${prio}" == "NONE" ]] && echo 1 || echo 0)"
+assert "PR no marker -> emits ::warning::" "$([[ "${out}" == *"::warning::"* ]] && echo 1 || echo 0)"
+
+echo ""
+echo "Passed: ${PASS}, Failed: ${FAIL}"
+[[ "${FAIL}" -eq 0 ]]
