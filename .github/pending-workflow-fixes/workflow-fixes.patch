@@ -13,7 +13,18 @@ set -euo pipefail
 
 PRIORITY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
   --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' 2>/dev/null \
-  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || echo "NONE")
+  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || true)
+
+if [[ -z "${PRIORITY}" ]]; then
+  # No parseable MAXIMUM_FIX_PRIORITY marker was found in any PR comment. This is
+  # NOT the same as the review explicitly reporting NONE — a genuine "good to
+  # merge" review still emits `MAXIMUM_FIX_PRIORITY:NONE`. An empty value means
+  # the review comment was missing/malformed (or the API call failed), so we
+  # failed to parse a verdict. Surface it loudly instead of silently coercing to
+  # NONE, so a real finding can't be dropped by a formatting slip unnoticed.
+  echo "::warning::Could not parse MAXIMUM_FIX_PRIORITY from PR #${PR_NUMBER} review comments — review output was missing or malformed. Defaulting to NONE, so the fix stage will be SKIPPED."
+  PRIORITY="NONE"
+fi
 
 echo "MAXIMUM_FIX_PRIORITY: ${PRIORITY}"
 echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
