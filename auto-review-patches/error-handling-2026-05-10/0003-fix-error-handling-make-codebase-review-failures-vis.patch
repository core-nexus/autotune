+#!/usr/bin/env bash
+set -euo pipefail
+
+# Open a GitHub issue summarizing a failed/cancelled workflow run.
+#
+# This is the default failure-notification path for the codebase-review
+# workflow. It uses only the built-in GITHUB_TOKEN — no extra secrets —
+# so a freshly-installed system has visible alerting out of the box.
+# Users who prefer Slack should swap this step per the README.
+#
+# Required env vars:
+#   GH_TOKEN
+#   REPO         - GitHub repository (owner/repo)
+#   RUN_URL      - link to the workflow run
+#   RUN_ID       - workflow run id (used in title for uniqueness)
+#   WORKFLOW     - workflow name (e.g. "Automated Codebase Review")
+#
+# Optional env vars:
+#   JOB_RESULTS  - newline-separated "<job-name>=<result>" entries to
+#                  include in the issue body. Pass any number of jobs;
+#                  unspecified jobs simply aren't listed.
+
+: "${REPO:?}" "${RUN_URL:?}" "${RUN_ID:?}" "${WORKFLOW:?}"
+
+title="${WORKFLOW} failed (run ${RUN_ID})"
+
+job_lines=""
+if [[ -n "${JOB_RESULTS:-}" ]]; then
+  while IFS= read -r line; do
+    [[ -z "${line}" ]] && continue
+    job_lines+="- ${line}"$'\n'
+  done <<< "${JOB_RESULTS}"
+fi
+
+body=$(cat <<EOF
+The **${WORKFLOW}** workflow failed or was cancelled.
+
+- Run: ${RUN_URL}
+
+Job results:
+${job_lines:-- (none reported)}
+
+See the run logs for details. Re-run from the Actions tab once the
+underlying issue is resolved.
+EOF
+)
+
+# Try with the auto-review label first; fall back to no label if the
+# label is missing in this repo. We accept best-effort here because the
+# alternative — failing the notify job — would itself be silent.
+if ! gh issue create --repo "${REPO}" \
+    --title "${title}" \
+    --body "${body}" \
+    --label auto-review 2>/tmp/notify-err.log; then
+  if grep -q -E 'label|404|not found' /tmp/notify-err.log; then
+    echo "WARN: creating issue with 'auto-review' label failed; retrying without label" >&2
+    gh issue create --repo "${REPO}" --title "${title}" --body "${body}"
+  else
+    cat /tmp/notify-err.log >&2
+    exit 1
+  fi
+fi
