@@ -0,0 +1,38 @@
+#!/usr/bin/env bash
+# Shared helpers for review workflow scripts. Source this; do not execute it.
+#
+# Public functions:
+#   gh_with_retry <args...>
+#     Invokes `gh` with up to 3 attempts and exponential backoff (1s, 2s).
+#     On success, prints captured stdout and returns 0.
+#     On final failure, prints captured output to stderr and returns gh's
+#     exit code so the caller can fail loudly.
+
+gh_with_retry() {
+  local attempt=1
+  local -r max_attempts=3
+  local delay=1
+  local out rc
+  while true; do
+    rc=0
+    # `|| rc=$?` is required: under `set -e`, an `if cmd; then` form swallows
+    # cmd's exit code (the if-statement itself exits 0 when no branch is
+    # taken), and a bare assignment would terminate the script. This idiom
+    # both preserves the real exit code and keeps the function alive.
+    out=$(gh "$@" 2>&1) || rc=$?
+    if (( rc == 0 )); then
+      printf '%s' "${out}"
+      return 0
+    fi
+    if (( attempt >= max_attempts )); then
+      printf 'ERROR: gh %s failed after %d attempts (exit %d):\n%s\n' \
+        "$*" "${attempt}" "${rc}" "${out}" >&2
+      return "${rc}"
+    fi
+    printf 'WARN: gh %s failed (attempt %d), retrying in %ds:\n%s\n' \
+      "$*" "${attempt}" "${delay}" "${out}" >&2
+    sleep "${delay}"
+    delay=$(( delay * 2 ))
+    attempt=$(( attempt + 1 ))
+  done
+}
