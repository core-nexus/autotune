@@ -8,11 +8,24 @@ set -euo pipefail
 #   GH_TOKEN
 #   REPO - GitHub repository (owner/repo)
 #   PR_NUMBER - the PR number
+#
+# Failure modes are surfaced loudly: if the GitHub API call fails (auth,
+# rate limit, 5xx, network), this script exits non-zero so the workflow
+# step fails. Only the legitimate "no priority token in any comment"
+# case maps to NONE.
 
 : "${GITHUB_OUTPUT:?}" "${REPO:?}" "${PR_NUMBER:?}"
 
-PRIORITY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
-  --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' 2>/dev/null \
+# shellcheck source=lib.sh
+source "$(dirname "$0")/lib.sh"
+
+if ! BODY=$(gh_with_retry api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
+    --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body'); then
+  echo "ERROR: failed to fetch PR comments via gh api" >&2
+  exit 1
+fi
+
+PRIORITY=$(printf '%s' "${BODY}" \
   | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || echo "NONE")
 
 echo "MAXIMUM_FIX_PRIORITY: ${PRIORITY}"
