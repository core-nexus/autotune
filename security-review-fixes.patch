@@ -0,0 +1,141 @@
+#!/usr/bin/env bash
+set -uo pipefail
+
+# Unit tests for the codebase-review shell scripts. These focus on the
+# security-relevant behavior hardened in the security review:
+#   - resolve-review-area.sh validates its input against an allowlist and writes
+#     injection-safe GITHUB_OUTPUT.
+#   - extract-*-priority.sh derive the fix gate only from the trusted execution
+#     file and fail closed (NONE) when it is absent.
+#
+# Run: bash .github/workflows/scripts/tests/run-tests.sh
+
+SCRIPTS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+RESOLVE="${SCRIPTS_DIR}/resolve-review-area.sh"
+EXTRACT_REVIEW="${SCRIPTS_DIR}/extract-review-priority.sh"
+EXTRACT_PR="${SCRIPTS_DIR}/extract-pr-review-priority.sh"
+
+ALL_AREAS='["security","privacy","compliance","ai-compliance","error-handling","code-quality","performance","testing","documentation","dependency-health","correctness","e-commerce"]'
+
+PASS=0
+FAIL=0
+pass() { printf '  ok   %s\n' "$1"; PASS=$((PASS + 1)); }
+fail() { printf '  FAIL %s\n' "$1"; FAIL=$((FAIL + 1)); }
+
+expect_eq() {
+  # $1 actual, $2 expected, $3 label
+  if [[ "$1" == "$2" ]]; then
+    pass "$3"
+  else
+    fail "$3 (got: '$1', want: '$2')"
+  fi
+}
+
+# Read a heredoc-delimited (__GHA_EOF__) value for KEY from a GITHUB_OUTPUT file.
+get_output() {
+  awk -v key="$1" '
+    $0 == key "<<__GHA_EOF__" { capture = 1; next }
+    capture && $0 == "__GHA_EOF__" { exit }
+    capture { out = (out == "" ? $0 : out "\n" $0) }
+    END { print out }
+  ' "$2"
+}
+
+echo "resolve-review-area.sh"
+
+# Valid single area resolves to a one-element JSON array.
+out="$(mktemp)"
+if env -u INPUT_REVIEW_AREA GITHUB_OUTPUT="$out" EVENT_NAME=workflow_dispatch \
+  INPUT_REVIEW_AREA=security bash "$RESOLVE" >/dev/null 2>&1; then
+  expect_eq "$(get_output areas_json "$out")" '["security"]' "valid area -> [\"security\"]"
+else
+  fail "valid area: script exited non-zero"
+fi
+rm -f "$out"
+
+# "all" expands to the full allowlist.
+out="$(mktemp)"
+GITHUB_OUTPUT="$out" EVENT_NAME=workflow_dispatch INPUT_REVIEW_AREA=all \
+  bash "$RESOLVE" >/dev/null 2>&1
+expect_eq "$(get_output areas_json "$out")" "$ALL_AREAS" "all -> full allowlist"
+rm -f "$out"
+
+# Schedule trigger runs the full allowlist.
+out="$(mktemp)"
+GITHUB_OUTPUT="$out" EVENT_NAME=schedule bash "$RESOLVE" >/dev/null 2>&1
+expect_eq "$(get_output areas_json "$out")" "$ALL_AREAS" "schedule -> full allowlist"
+rm -f "$out"
+
+# Unknown area is rejected (non-zero exit, nothing written).
+out="$(mktemp)"
+if GITHUB_OUTPUT="$out" EVENT_NAME=workflow_dispatch INPUT_REVIEW_AREA=evil \
+  bash "$RESOLVE" >/dev/null 2>&1; then
+  fail "unknown area should be rejected"
+elif [[ -s "$out" ]]; then
+  fail "unknown area wrote output"
+else
+  pass "unknown area rejected, no output"
+fi
+rm -f "$out"
+
+# Injection attempt (embedded newline) is rejected and never reaches GITHUB_OUTPUT.
+out="$(mktemp)"
+if GITHUB_OUTPUT="$out" EVENT_NAME=workflow_dispatch \
+  INPUT_REVIEW_AREA=$'security\nMALICIOUS=1' bash "$RESOLVE" >/dev/null 2>&1; then
+  fail "newline-injection area should be rejected"
+elif grep -q MALICIOUS "$out"; then
+  fail "injected output leaked"
+else
+  pass "newline injection rejected"
+fi
+rm -f "$out"
+
+# Default area (input unset on workflow_dispatch) is the valid "security".
+out="$(mktemp)"
+if env -u INPUT_REVIEW_AREA GITHUB_OUTPUT="$out" EVENT_NAME=workflow_dispatch \
+  bash "$RESOLVE" >/dev/null 2>&1; then
+  expect_eq "$(get_output areas_json "$out")" '["security"]' "unset input -> default security"
+else
+  fail "default area: script exited non-zero"
+fi
+rm -f "$out"
+
+run_extract_case() {
+  # $1 label, $2 script, $3 expected, $4 execution-file-contents, $5 set-file (1/0)
+  local label="$1" script="$2" expected="$3" contents="$4" setfile="$5"
+  local out ef
+  out="$(mktemp)"
+  if [[ "$setfile" == "1" ]]; then
+    ef="$(mktemp)"
+    printf '%s' "$contents" > "$ef"
+    env -u EXECUTION_FILE GITHUB_OUTPUT="$out" REVIEW_AREA=security \
+      EXECUTION_FILE="$ef" bash "$script" >/dev/null 2>&1
+    rm -f "$ef"
+  else
+    env -u EXECUTION_FILE GITHUB_OUTPUT="$out" REVIEW_AREA=security \
+      bash "$script" >/dev/null 2>&1
+  fi
+  expect_eq "$(get_output priority "$out")" "$expected" "$label"
+  rm -f "$out"
+}
+
+for s in "extract-review-priority.sh:$EXTRACT_REVIEW" "extract-pr-review-priority.sh:$EXTRACT_PR"; do
+  name="${s%%:*}"
+  path="${s##*:}"
+  echo "$name"
+  run_extract_case "HIGH from execution file" "$path" HIGH $'note\nMAXIMUM_FIX_PRIORITY:HIGH\n' 1
+  run_extract_case "last marker wins" "$path" HIGH $'MAXIMUM_FIX_PRIORITY:MEDIUM\nMAXIMUM_FIX_PRIORITY:HIGH\n' 1
+  run_extract_case "no marker -> NONE" "$path" NONE $'just some text\n' 1
+  run_extract_case "missing file path -> NONE (fail closed)" "$path" NONE "" 0
+done
+
+# Missing-file (path set but nonexistent) also fails closed.
+out="$(mktemp)"
+env -u EXECUTION_FILE GITHUB_OUTPUT="$out" REVIEW_AREA=security \
+  EXECUTION_FILE=/nonexistent/execution.json bash "$EXTRACT_REVIEW" >/dev/null 2>&1
+expect_eq "$(get_output priority "$out")" NONE "nonexistent execution file -> NONE"
+rm -f "$out"
+
+echo
+printf 'Passed: %d, Failed: %d\n' "$PASS" "$FAIL"
+[[ "$FAIL" -eq 0 ]]
