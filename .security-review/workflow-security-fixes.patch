--- a/.github/workflows/claude-pr-review.yml
+++ b/.github/workflows/claude-pr-review.yml
@@ -2,6 +2,19 @@ name: Claude PR Review
 
 # Two-stage pipeline: review → fix (if needed).
 # Triggers: PR events (auto), /claude-review (manual review), /claude-fix (manual fix).
+#
+# SECURITY NOTE — untrusted input flows into an autonomous agent.
+# The review/fix jobs read PR diffs and PR/issue comments, which are
+# attacker-influenceable on public repos, and run Claude with a scoped
+# OAuth token (and, for the fix job, `contents: write`). That content is a
+# prompt-injection channel. Two guardrails keep the blast radius small:
+#   1. The `issue_comment` command triggers below are gated on
+#      `author_association` so only OWNER/MEMBER/COLLABORATOR can invoke
+#      `/claude-review` and `/claude-fix` (see each job's `if:`).
+#   2. This workflow declares a deny-all `permissions:` floor and each job
+#      grants only the scopes it needs (least privilege).
+# Install this workflow only on repos where you trust the maintainers who
+# can run these commands.
 
 on:
   pull_request:
@@ -11,6 +24,9 @@ on:
   issue_comment:
     types: [created]
 
+# Deny-all floor; each job re-grants only the scopes it needs.
+permissions: {}
+
 concurrency:
   group: ${{ github.workflow }}-${{ github.event.pull_request.number || github.event.issue.number }}
   cancel-in-progress: ${{ github.event_name == 'pull_request' }}
@@ -18,10 +34,11 @@ concurrency:
 jobs:
   # ─── Stage 1: Review ───────────────────────────────────────────────────────
   review:
-    # Run on PR events (not dependabot), or on "/claude-review" comments on PRs
+    # Run on PR events (not dependabot), or on "/claude-review" comments posted
+    # by a repo owner/member/collaborator (privileged trigger — see SECURITY NOTE).
     if: |
       (github.event_name == 'pull_request' && github.actor != 'dependabot[bot]') ||
-      (github.event_name == 'issue_comment' && github.event.issue.pull_request && !endsWith(github.actor, '[bot]') && contains(github.event.comment.body, '/claude-review'))
+      (github.event_name == 'issue_comment' && github.event.issue.pull_request && !endsWith(github.actor, '[bot]') && contains(fromJson('["OWNER","MEMBER","COLLABORATOR"]'), github.event.comment.author_association) && startsWith(github.event.comment.body, '/claude-review'))
     runs-on: ubuntu-latest
     timeout-minutes: 30
     permissions:
@@ -33,13 +50,13 @@ jobs:
       follow_up: ${{ steps.check-followup.outputs.priority }}
     steps:
       - name: Checkout repository
-        uses: actions/checkout@v4
+        uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4
         with:
           fetch-depth: 1
 
       - name: PR Review
         id: review
-        uses: anthropics/claude-code-action@v1
+        uses: anthropics/claude-code-action@558b1d6cab4085c7753fe402c10bef0fbb92ac7a # v1
         with:
           claude_code_oauth_token: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}
           track_progress: true
@@ -136,10 +153,11 @@ jobs:
   fix-review-issues:
     needs: review
     # Run after review if priority is LOW/MEDIUM/HIGH, or directly on "/claude-fix"
+    # posted by a repo owner/member/collaborator (privileged trigger — see SECURITY NOTE).
     if: |
       always() && (
         (needs.review.result == 'success' && (needs.review.outputs.follow_up == 'HIGH' || needs.review.outputs.follow_up == 'MEDIUM' || needs.review.outputs.follow_up == 'LOW')) ||
-        (github.event_name == 'issue_comment' && github.event.issue.pull_request && !endsWith(github.actor, '[bot]') && contains(github.event.comment.body, '/claude-fix'))
+        (github.event_name == 'issue_comment' && github.event.issue.pull_request && !endsWith(github.actor, '[bot]') && contains(fromJson('["OWNER","MEMBER","COLLABORATOR"]'), github.event.comment.author_association) && startsWith(github.event.comment.body, '/claude-fix'))
       )
     runs-on: ubuntu-latest
     timeout-minutes: 120
@@ -151,12 +169,12 @@ jobs:
       actions: read
     steps:
       - name: Checkout repository
-        uses: actions/checkout@v4
+        uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4
         with:
           fetch-depth: 1
 
       - name: Fix review issues
-        uses: anthropics/claude-code-action@v1
+        uses: anthropics/claude-code-action@558b1d6cab4085c7753fe402c10bef0fbb92ac7a # v1
         with:
           claude_code_oauth_token: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}
           track_progress: true
