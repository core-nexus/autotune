diff --git a/.github/workflows/scripts/extract-pr-review-priority.sh b/.github/workflows/scripts/extract-pr-review-priority.sh
index c28572e..944bcfb 100755
--- a/.github/workflows/scripts/extract-pr-review-priority.sh
+++ b/.github/workflows/scripts/extract-pr-review-priority.sh
@@ -1,19 +1,37 @@
 #!/usr/bin/env bash
 set -euo pipefail
 
-# Extract MAXIMUM_FIX_PRIORITY from the latest PR review comment.
+# Extract MAXIMUM_FIX_PRIORITY for a PR review.
+#
+# The priority gates whether the privileged, contents:write fix job runs, so it
+# MUST come from a trusted source. The authoritative source is the review step's
+# own execution file (EXECUTION_FILE) — the verbatim output of the review agent.
+# We deliberately do NOT parse arbitrary PR/issue comments, which any user can
+# spoof to force (or suppress) the fix job.
 #
 # Required env vars:
 #   GITHUB_OUTPUT
-#   GH_TOKEN
-#   REPO - GitHub repository (owner/repo)
-#   PR_NUMBER - the PR number
+#   REPO       - GitHub repository (owner/repo)
+#   PR_NUMBER  - the PR number
+#
+# Optional env vars:
+#   EXECUTION_FILE - path to the claude-code-action execution file (trusted)
 
 : "${GITHUB_OUTPUT:?}" "${REPO:?}" "${PR_NUMBER:?}"
 
-PRIORITY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
-  --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' 2>/dev/null \
-  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || echo "NONE")
+PRIORITY=""
+
+if [[ -n "${EXECUTION_FILE:-}" ]] && [[ -f "${EXECUTION_FILE}" ]]; then
+  PRIORITY=$(grep -oP 'MAXIMUM_FIX_PRIORITY:\K[A-Z_]+' "${EXECUTION_FILE}" \
+    | tail -1 || true)
+  echo "Extracted from execution file: ${PRIORITY:-<empty>}"
+else
+  # No trusted source available — fail safe (NONE means the fix job does not
+  # run). Log loudly so a genuine failure is not silently treated as "clean".
+  echo "::warning::No execution file found at '${EXECUTION_FILE:-<unset>}'; defaulting priority to NONE (fix job will not run)."
+fi
 
+# Fail closed: anything we could not establish from the trusted source is NONE.
+PRIORITY="${PRIORITY:-NONE}"
 echo "MAXIMUM_FIX_PRIORITY: ${PRIORITY}"
 echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
diff --git a/.github/workflows/scripts/extract-review-priority.sh b/.github/workflows/scripts/extract-review-priority.sh
index 185b2d4..80292e2 100755
--- a/.github/workflows/scripts/extract-review-priority.sh
+++ b/.github/workflows/scripts/extract-review-priority.sh
@@ -28,15 +28,23 @@ fi
 # Method 2 (fallback): list recent issues via REST API
 if [[ -z "${PRIORITY}" ]]; then
   echo "Falling back to gh issue list..."
-  BODY=$(gh issue list \
-    --repo "${REPO}" \
-    --state all --limit 10 \
-    --json title,body \
-    --jq "[.[] | select(.title | startswith(\"review(${REVIEW_AREA})\"))] | .[0].body" \
-    2>/dev/null || true)
-  PRIORITY=$(echo "${BODY}" \
-    | grep -oP 'MAXIMUM_FIX_PRIORITY:\K[A-Z_]+' || true)
-  echo "Extracted from issue list: ${PRIORITY:-<empty>}"
+  # Fetch raw JSON, then filter with a standalone jq that supports --arg, so
+  # REVIEW_AREA is passed as data and can never be parsed as jq program text.
+  if ISSUES_JSON=$(gh issue list \
+      --repo "${REPO}" \
+      --state all --limit 10 \
+      --json title,body); then
+    BODY=$(echo "${ISSUES_JSON}" \
+      | jq -r --arg area "${REVIEW_AREA}" \
+          '[.[] | select(.title | startswith("review(" + $area + ")"))] | .[0].body // ""')
+    PRIORITY=$(echo "${BODY}" \
+      | grep -oP 'MAXIMUM_FIX_PRIORITY:\K[A-Z_]+' || true)
+    echo "Extracted from issue list: ${PRIORITY:-<empty>}"
+  else
+    # Surface the real failure (auth error, rate limit, ...) instead of
+    # silently treating it as "no priority found".
+    echo "::warning::gh issue list failed while extracting priority for '${REVIEW_AREA}'; defaulting to NONE."
+  fi
 fi
 
 PRIORITY="${PRIORITY:-NONE}"
