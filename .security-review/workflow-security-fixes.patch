diff --git a/.github/workflows/scripts/extract-review-priority.sh b/.github/workflows/scripts/extract-review-priority.sh
index 185b2d4..a595e52 100755
--- a/.github/workflows/scripts/extract-review-priority.sh
+++ b/.github/workflows/scripts/extract-review-priority.sh
@@ -28,11 +28,16 @@ fi
 # Method 2 (fallback): list recent issues via REST API
 if [[ -z "${PRIORITY}" ]]; then
   echo "Falling back to gh issue list..."
+  # Pass REVIEW_AREA to jq as a named argument (--arg) rather than interpolating
+  # it into the jq program text, so the value can never be parsed as jq syntax.
+  # (`gh --jq` does not accept `--arg`, so pipe the raw JSON to jq instead.)
   BODY=$(gh issue list \
     --repo "${REPO}" \
     --state all --limit 10 \
     --json title,body \
-    --jq "[.[] | select(.title | startswith(\"review(${REVIEW_AREA})\"))] | .[0].body" \
+    2>/dev/null \
+    | jq -r --arg area "${REVIEW_AREA}" \
+        '[.[] | select(.title | startswith("review(" + $area + ")"))] | .[0].body // ""' \
     2>/dev/null || true)
   PRIORITY=$(echo "${BODY}" \
     | grep -oP 'MAXIMUM_FIX_PRIORITY:\K[A-Z_]+' || true)
diff --git a/.github/workflows/scripts/resolve-review-area.sh b/.github/workflows/scripts/resolve-review-area.sh
index 71631a5..8b51a95 100755
--- a/.github/workflows/scripts/resolve-review-area.sh
+++ b/.github/workflows/scripts/resolve-review-area.sh
@@ -19,6 +19,14 @@ if [[ "${EVENT_NAME}" = "workflow_dispatch" ]]; then
   if [[ "${AREA}" = "all" ]]; then
     echo "areas_json=${ALL_AREAS}" >> "${GITHUB_OUTPUT}"
   else
+    # Validate AREA against the known list before writing it to GITHUB_OUTPUT.
+    # GitHub already constrains `choice` inputs, but validating here is
+    # defense-in-depth: it rejects any value (e.g. one containing a newline)
+    # that could inject additional workflow outputs.
+    if ! echo "${ALL_AREAS}" | jq -e --arg area "${AREA}" 'index($area) != null' >/dev/null; then
+      echo "::error::Invalid review area: '${AREA}'. Must be one of ${ALL_AREAS} or 'all'." >&2
+      exit 1
+    fi
     echo "areas_json=[\"${AREA}\"]" >> "${GITHUB_OUTPUT}"
   fi
 else
