diff --git a/.github/workflows/scripts/resolve-review-area.sh b/.github/workflows/scripts/resolve-review-area.sh
index 71631a5..d2bf450 100755
--- a/.github/workflows/scripts/resolve-review-area.sh
+++ b/.github/workflows/scripts/resolve-review-area.sh
@@ -12,14 +12,36 @@ set -euo pipefail
 
 : "${GITHUB_OUTPUT:?}" "${EVENT_NAME:?}"
 
-ALL_AREAS='["security","privacy","compliance","ai-compliance","error-handling","code-quality","performance","testing","documentation","dependency-health","correctness","e-commerce"]'
+# Single source of truth for the known review areas. The JSON array form
+# consumed by the workflow matrix is derived from this list so the two can
+# never drift apart.
+KNOWN_AREAS=(
+  security privacy compliance ai-compliance error-handling code-quality
+  performance testing documentation dependency-health correctness e-commerce
+)
+
+ALL_AREAS=$(printf '"%s",' "${KNOWN_AREAS[@]}")
+ALL_AREAS="[${ALL_AREAS%,}]"
+
+# is_known_area <area> — return 0 if the argument is one of the known areas.
+is_known_area() {
+  local candidate="$1" area
+  for area in "${KNOWN_AREAS[@]}"; do
+    [[ "${candidate}" = "${area}" ]] && return 0
+  done
+  return 1
+}
 
 if [[ "${EVENT_NAME}" = "workflow_dispatch" ]]; then
   AREA="${INPUT_REVIEW_AREA:-security}"
   if [[ "${AREA}" = "all" ]]; then
     echo "areas_json=${ALL_AREAS}" >> "${GITHUB_OUTPUT}"
-  else
+  elif is_known_area "${AREA}"; then
     echo "areas_json=[\"${AREA}\"]" >> "${GITHUB_OUTPUT}"
+  else
+    echo "Error: unknown review area '${AREA}'." >&2
+    echo "Valid areas: ${KNOWN_AREAS[*]} all" >&2
+    exit 1
   fi
 else
   # Schedule trigger: run all areas at once (Sunday morning)
