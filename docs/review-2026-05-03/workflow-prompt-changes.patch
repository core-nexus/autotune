diff --git a/tests/scripts/test-extract-pr-review-priority.sh b/tests/scripts/test-extract-pr-review-priority.sh
new file mode 100755
index 0000000..6dca812
--- /dev/null
+++ b/tests/scripts/test-extract-pr-review-priority.sh
@@ -0,0 +1,107 @@
+#!/usr/bin/env bash
+# Tests for .github/workflows/scripts/extract-pr-review-priority.sh
+#
+# Same AI-safety contract as the codebase-review variant: a parse failure must
+# not silently default to NONE without a workflow warning.
+
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
+TARGET="${REPO_ROOT}/.github/workflows/scripts/extract-pr-review-priority.sh"
+
+PASS=0
+FAIL=0
+FAILED_NAMES=()
+
+# Stub gh — script invokes `gh api ... --jq ...`. Return whatever the test puts
+# in GH_STUB_OUTPUT.
+TMP_BIN="$(mktemp -d)"
+cat >"${TMP_BIN}/gh" <<'EOF'
+#!/usr/bin/env bash
+printf '%s' "${GH_STUB_OUTPUT:-}"
+EOF
+chmod +x "${TMP_BIN}/gh"
+export PATH="${TMP_BIN}:${PATH}"
+
+run_case() {
+  local name="$1"
+  local stub_output="$2"
+  local expected_priority="$3"
+  local expected_status="$4"
+
+  local output_file
+  output_file="$(mktemp)"
+
+  local stdout
+  if ! stdout=$(
+    GITHUB_OUTPUT="${output_file}" \
+    REPO="acme/test" \
+    PR_NUMBER="123" \
+    GH_TOKEN="dummy" \
+    GH_STUB_OUTPUT="${stub_output}" \
+    bash "${TARGET}" 2>&1
+  ); then
+    echo "FAIL: ${name} — script exited non-zero"
+    printf '%s\n' "  ${stdout//$'\n'/$'\n'  }"
+    FAIL=$((FAIL + 1))
+    FAILED_NAMES+=("${name}")
+    rm -f "${output_file}"
+    return
+  fi
+
+  local got_priority got_status
+  got_priority=$(grep '^priority=' "${output_file}" | tail -1 | cut -d= -f2-)
+  got_status=$(grep '^parse_status=' "${output_file}" | tail -1 | cut -d= -f2-)
+
+  if [[ "${got_priority}" != "${expected_priority}" || "${got_status}" != "${expected_status}" ]]; then
+    echo "FAIL: ${name}"
+    echo "  expected priority=${expected_priority} parse_status=${expected_status}"
+    echo "  got      priority=${got_priority} parse_status=${got_status}"
+    echo "  stdout:"
+    printf '%s\n' "    ${stdout//$'\n'/$'\n'    }"
+    FAIL=$((FAIL + 1))
+    FAILED_NAMES+=("${name}")
+  else
+    PASS=$((PASS + 1))
+  fi
+
+  if [[ "${expected_status}" = "parse_failed" || "${expected_status}" = "unknown_value" ]]; then
+    if ! grep -q '^::warning' <<<"${stdout}"; then
+      echo "FAIL: ${name} — expected a ::warning:: line on parse failure, got none"
+      FAIL=$((FAIL + 1))
+      FAILED_NAMES+=("${name}-warning")
+    else
+      PASS=$((PASS + 1))
+    fi
+  fi
+
+  rm -f "${output_file}"
+}
+
+# Happy path for each canonical value.
+for value in NONE XLOW LOW MEDIUM HIGH; do
+  run_case "canonical_${value}" "review body...\n\nMAXIMUM_FIX_PRIORITY:${value}\n" "${value}" "ok"
+done
+
+# Whitespace and case tolerance.
+run_case "whitespace_after_colon" "body\n\nMAXIMUM_FIX_PRIORITY: HIGH\n" "HIGH" "ok"
+run_case "lowercase_value" "body\n\nMAXIMUM_FIX_PRIORITY:high\n" "HIGH" "ok"
+
+# No comment with marker exists at all (gh returns "" or "null") → NONE / no_marker.
+run_case "no_review_yet" "" "NONE" "no_marker"
+run_case "null_returned" "null" "NONE" "no_marker"
+
+# Comment exists and contains the substring but the value cannot be parsed.
+run_case "marker_substring_only" "We discussed MAXIMUM_FIX_PRIORITY but didn't pick one." "NONE" "parse_failed"
+
+# Comment exists with an unknown value.
+run_case "unknown_value" "body\n\nMAXIMUM_FIX_PRIORITY:URGENT\n" "NONE" "unknown_value"
+
+echo ""
+echo "passed: ${PASS}"
+echo "failed: ${FAIL}"
+if [[ "${FAIL}" -gt 0 ]]; then
+  printf 'failed cases: %s\n' "${FAILED_NAMES[*]}"
+  exit 1
+fi
