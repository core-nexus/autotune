+    # workflow file does not exist in the repo. That is the expected-benign case.
+    if grep -qiE 'could not find|not found|no workflow' <<<"${err_msg}"; then
+      echo "     skipped: ${workflow} (no such workflow in this repo)"
+    else
+      echo "::warning title=CI dispatch failed::Failed to dispatch ${workflow} on ${BRANCH} (exit=${rc}). This may be auth, rate limiting, or a GitHub outage — auto-fix branches will not run CI until this is investigated. Error: ${err_msg}"
