+++ b/tests/scripts/test-extract-review-priority.sh
@@ -0,0 +1,115 @@
+#!/usr/bin/env bash
+# Tests for .github/workflows/scripts/extract-review-priority.sh
+#
+# Covers the AI-safety contract that a parse failure must NOT silently default
+# to NONE: the script emits a workflow warning, sets parse_status=parse_failed,
+# and only returns priority=NONE while making the failure mode visible.
+
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
+TARGET="${REPO_ROOT}/.github/workflows/scripts/extract-review-priority.sh"
+
+PASS=0
+FAIL=0
+FAILED_NAMES=()
+
+# Stub out gh so the fallback never reaches the network.
+TMP_BIN="$(mktemp -d)"
+cat >"${TMP_BIN}/gh" <<'EOF'
+#!/usr/bin/env bash
+echo ""
+EOF
+chmod +x "${TMP_BIN}/gh"
+export PATH="${TMP_BIN}:${PATH}"
+
+run_case() {
+  local name="$1"
+  local fixture_content="$2"
+  local expected_priority="$3"
+  local expected_status="$4"
+
+  local fixture_file
+  fixture_file="$(mktemp)"
+  printf '%s' "${fixture_content}" >"${fixture_file}"
+
+  local output_file
+  output_file="$(mktemp)"
+
+  local stdout
+  if ! stdout=$(
+    GITHUB_OUTPUT="${output_file}" \
+    REVIEW_AREA="testing" \
+    REPO="acme/test" \
+    EXECUTION_FILE="${fixture_file}" \
+    GH_TOKEN="dummy" \
+    bash "${TARGET}" 2>&1
+  ); then
+    echo "FAIL: ${name} — script exited non-zero"
+    printf '%s\n' "  ${stdout//$'\n'/$'\n'  }"
+    FAIL=$((FAIL + 1))
+    FAILED_NAMES+=("${name}")
+    rm -f "${fixture_file}" "${output_file}"
+    return
+  fi
+
+  local got_priority got_status
+  got_priority=$(grep '^priority=' "${output_file}" | tail -1 | cut -d= -f2-)
+  got_status=$(grep '^parse_status=' "${output_file}" | tail -1 | cut -d= -f2-)
+
+  if [[ "${got_priority}" != "${expected_priority}" || "${got_status}" != "${expected_status}" ]]; then
+    echo "FAIL: ${name}"
+    echo "  expected priority=${expected_priority} parse_status=${expected_status}"
+    echo "  got      priority=${got_priority} parse_status=${got_status}"
+    echo "  stdout:"
+    printf '%s\n' "    ${stdout//$'\n'/$'\n'    }"
+    FAIL=$((FAIL + 1))
+    FAILED_NAMES+=("${name}")
+  else
+    PASS=$((PASS + 1))
+  fi
+
+  # If the expected status is a parse failure, verify a workflow warning was emitted.
+  if [[ "${expected_status}" = "parse_failed" || "${expected_status}" = "unknown_value" ]]; then
+    if ! grep -q '^::warning' <<<"${stdout}"; then
+      echo "FAIL: ${name} — expected a ::warning:: line on parse failure, got none"
+      FAIL=$((FAIL + 1))
+      FAILED_NAMES+=("${name}-warning")
+    else
+      PASS=$((PASS + 1))
+    fi
+  fi
+
+  rm -f "${fixture_file}" "${output_file}"
+}
+
+# Happy path: each canonical priority is recognised.
+for value in NONE XLOW LOW MEDIUM HIGH; do
+  run_case "canonical_${value}" "Findings...\n\nMAXIMUM_FIX_PRIORITY:${value}\n" "${value}" "ok"
+done
+
+# Whitespace tolerance after the colon.
+run_case "whitespace_after_colon" "Body\n\nMAXIMUM_FIX_PRIORITY: HIGH\n" "HIGH" "ok"
+run_case "tab_after_colon" "$(printf 'Body\n\nMAXIMUM_FIX_PRIORITY:\tMEDIUM\n')" "MEDIUM" "ok"
+
+# Case-insensitive value (model formatting drift).
+run_case "lowercase_value" "Body\n\nMAXIMUM_FIX_PRIORITY:high\n" "HIGH" "ok"
+run_case "mixed_case_value" "Body\n\nMAXIMUM_FIX_PRIORITY:Medium\n" "MEDIUM" "ok"
+
+# Multiple markers — last one wins (matches model behaviour: final summary line).
+run_case "multiple_markers_last_wins" "MAXIMUM_FIX_PRIORITY:NONE\n\nlater...\n\nMAXIMUM_FIX_PRIORITY:HIGH\n" "HIGH" "ok"
+
+# Parse failure: no marker at all → NONE with parse_failed and warning.
+run_case "missing_marker" "Just a normal review body with no marker line at all.\n" "NONE" "parse_failed"
+
+# Parse failure: malformed marker → NONE with unknown_value and warning.
+run_case "unknown_value" "Body\n\nMAXIMUM_FIX_PRIORITY:URGENT\n" "NONE" "unknown_value"
+
+echo ""
+echo "passed: ${PASS}"
+echo "failed: ${FAIL}"
+if [[ "${FAIL}" -gt 0 ]]; then
+  printf 'failed cases: %s\n' "${FAILED_NAMES[*]}"
+  exit 1
+fi
