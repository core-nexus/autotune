@@ -0,0 +1,105 @@
+#!/usr/bin/env bash
+# Tests for .github/workflows/scripts/trigger-ci-workflows.sh
+#
+# Verifies that:
+#  - successful dispatches succeed (exit 0)
+#  - "workflow not found" is treated as benign (exit 0, no warning)
+#  - any other gh failure is surfaced as ::warning:: AND fails the step (exit 1)
+
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
+TARGET="${REPO_ROOT}/.github/workflows/scripts/trigger-ci-workflows.sh"
+
+PASS=0
+FAIL=0
+FAILED_NAMES=()
+
+# Build a stub directory we'll prepend to PATH per-case.
+make_gh_stub() {
+  local mode="$1"
+  local dir
+  dir="$(mktemp -d)"
+  case "${mode}" in
+    success)
+      cat >"${dir}/gh" <<'EOF'
+#!/usr/bin/env bash
+echo "dispatched"
+exit 0
+EOF
+      ;;
+    not_found)
+      cat >"${dir}/gh" <<'EOF'
+#!/usr/bin/env bash
+echo "could not find any workflows named $3" >&2
+exit 1
+EOF
+      ;;
+    auth_failure)
+      cat >"${dir}/gh" <<'EOF'
+#!/usr/bin/env bash
+echo "HTTP 401: Bad credentials" >&2
+exit 1
+EOF
+      ;;
+  esac
+  chmod +x "${dir}/gh"
+  echo "${dir}"
+}
+
+run_case() {
+  local name="$1"
+  local mode="$2"
+  local expected_rc="$3"
+  local expects_warning="$4"  # "yes" or "no"
+
+  local stub
+  stub="$(make_gh_stub "${mode}")"
+
+  local stdout
+  local rc=0
+  stdout=$(
+    PATH="${stub}:${PATH}" \
+    REPO="acme/test" \
+    BRANCH="review/test-branch" \
+    bash "${TARGET}" 2>&1
+  ) || rc=$?
+
+  if [[ "${rc}" != "${expected_rc}" ]]; then
+    echo "FAIL: ${name} — expected exit ${expected_rc}, got ${rc}"
+    printf '%s\n' "  ${stdout//$'\n'/$'\n'  }"
+    FAIL=$((FAIL + 1))
+    FAILED_NAMES+=("${name}")
+    rm -rf "${stub}"
+    return
+  fi
+
+  local has_warning="no"
+  if grep -q '^::warning' <<<"${stdout}"; then
+    has_warning="yes"
+  fi
+
+  if [[ "${has_warning}" != "${expects_warning}" ]]; then
+    echo "FAIL: ${name} — expected warning=${expects_warning}, got warning=${has_warning}"
+    printf '%s\n' "  ${stdout//$'\n'/$'\n'  }"
+    FAIL=$((FAIL + 1))
+    FAILED_NAMES+=("${name}")
+  else
+    PASS=$((PASS + 1))
+  fi
+
+  rm -rf "${stub}"
+}
+
+run_case "all_dispatched" "success" "0" "no"
+run_case "all_workflows_missing_is_benign" "not_found" "0" "no"
+run_case "auth_failure_is_surfaced" "auth_failure" "1" "yes"
+
+echo ""
+echo "passed: ${PASS}"
+echo "failed: ${FAIL}"
+if [[ "${FAIL}" -gt 0 ]]; then
+  printf 'failed cases: %s\n' "${FAILED_NAMES[*]}"
+  exit 1
+fi
