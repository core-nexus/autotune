 #
 # If WORKFLOWS is not set, this script will attempt to trigger common CI
 # workflow names. Customize the WORKFLOWS variable for your project.
+#
+# Error handling: a missing / non-dispatchable workflow is a benign skip, but
+# any OTHER dispatch failure (auth, rate limit, network) must be surfaced — a
+# silent failure here means CI never runs on the fix PR while the step reports
+# success. We distinguish a genuine 404 from a real error and exit non-zero if
+# any real dispatch failure occurred.
 
 : "${REPO:?}" "${BRANCH:?}"
 
@@ -20,8 +26,25 @@ set -euo pipefail
 WORKFLOWS="${WORKFLOWS:-ci.yml checks.yml test.yml}"
 
 echo "Triggering CI workflows on branch: ${BRANCH}"
+failures=0
 for workflow in ${WORKFLOWS}; do
   echo "  -> ${workflow}"
-  gh workflow run "${workflow}" --ref "${BRANCH}" --repo "${REPO}" 2>/dev/null \
-    || echo "  Skipped: ${workflow} (not found or not dispatchable)"
+  if err=$(gh workflow run "${workflow}" --ref "${BRANCH}" --repo "${REPO}" 2>&1); then
+    echo "  Triggered: ${workflow}"
+    continue
+  fi
+  # Only a genuine "workflow not found" is a benign skip; treat everything
+  # else (auth, rate limit, network) as a real failure that must be visible.
+  if grep -qiE 'could not find|not found|HTTP 404' <<<"${err}"; then
+    echo "  Skipped: ${workflow} (not found or not dispatchable)"
+  else
+    echo "  ERROR: failed to dispatch ${workflow}:" >&2
+    echo "${err}" >&2
+    failures=$((failures + 1))
+  fi
 done
+
+if [[ "${failures}" -gt 0 ]]; then
+  echo "ERROR: ${failures} workflow dispatch(es) failed for a non-benign reason." >&2
+  exit 1
+fi
