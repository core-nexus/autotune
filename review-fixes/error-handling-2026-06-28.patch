--- a/.github/workflows/scripts/extract-pr-review-priority.sh
+++ b/.github/workflows/scripts/extract-pr-review-priority.sh
@@ -8,12 +8,39 @@ set -euo pipefail
 #   GH_TOKEN
 #   REPO - GitHub repository (owner/repo)
 #   PR_NUMBER - the PR number
+#
+# Error handling: a failed `gh api` call (auth, rate limit, network) must NOT
+# be hidden and turned into a benign "NONE" — that would silently skip the fix
+# stage with no signal. We surface the API failure (log stderr, emit
+# `priority=ERROR`, exit non-zero). Only an API call that *succeeds* with no
+# matching comment is treated as a real "NONE".
 
 : "${GITHUB_OUTPUT:?}" "${REPO:?}" "${PR_NUMBER:?}"
 
-PRIORITY=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
-  --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' 2>/dev/null \
-  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' || echo "NONE")
+err_file=$(mktemp)
+trap 'rm -f "${err_file}"' EXIT
+
+# Separate the API call from the parse.
+if ! COMMENTS=$(gh api "repos/${REPO}/issues/${PR_NUMBER}/comments" \
+    --jq '[.[] | select(.body | test("MAXIMUM_FIX_PRIORITY:"))] | last | .body' \
+    2>"${err_file}"); then
+  echo "gh api stderr:" >&2
+  cat "${err_file}" >&2
+  echo "ERROR: failed to fetch comments for ${REPO} PR ${PR_NUMBER}" >&2
+  echo "priority=ERROR" >> "${GITHUB_OUTPUT}"
+  exit 1
+fi
+
+# API call succeeded — an empty / no-match result genuinely means "no priority".
+grep_status=0
+PRIORITY=$(printf '%s' "${COMMENTS}" \
+  | grep -oP '(?<=MAXIMUM_FIX_PRIORITY:)[A-Z_]+' | tail -1) || grep_status=$?
+if [[ "${grep_status}" -gt 1 ]]; then
+  echo "ERROR: failed to parse PR comments (grep exit ${grep_status})" >&2
+  echo "priority=ERROR" >> "${GITHUB_OUTPUT}"
+  exit 1
+fi
 
+PRIORITY="${PRIORITY:-NONE}"
 echo "MAXIMUM_FIX_PRIORITY: ${PRIORITY}"
 echo "priority=${PRIORITY}" >> "${GITHUB_OUTPUT}"
